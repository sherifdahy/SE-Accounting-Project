<UserControl x:Class="SA.Accounting.WPF.Contols.HeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="64"
             d:DesignWidth="1000"
             FlowDirection="RightToLeft">

    <Border Background="White"
            BorderBrush="#E5E7EB"
            BorderThickness="0,0,0,1"
            Padding="24,0"
            Height="64">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Page Title -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock x:Name="PageTitleHeader"
                           Text="لوحة التحكم"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#111827"/>
                <TextBlock x:Name="PageSubtitleHeader"
                           Text="نظام إدارة المحاسبة"
                           FontSize="12"
                           Foreground="#6B7280"
                           Margin="0,3,0,0"/>
            </StackPanel>

            <!-- Right -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <Button x:Name="UserMenuBtn"
                        Style="{StaticResource HeaderAvatarButtonStyle}"
                        Command="{Binding ToggleUserMenuCommand}">
                    <TextBlock Text="AM"
                               Foreground="#1F2937"
                               FontSize="12"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Popup x:Name="UserMenuPopup"
                       PlacementTarget="{Binding ElementName=UserMenuBtn}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       VerticalOffset="6"
                       IsOpen="{Binding IsUserMenuOpen, Mode=TwoWay}">

                    <Border Style="{StaticResource HeaderPopupContainerStyle}"
                            MinWidth="240">
                        <Border.Effect>
                            <DropShadowEffect Color="Black"
                                              Opacity="0.15"
                                              BlurRadius="20"
                                              Direction="270"
                                              ShadowDepth="4"/>
                        </Border.Effect>

                        <StackPanel>
                            <Border Style="{StaticResource HeaderUserInfoBoxStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Style="{StaticResource HeaderAvatarCircleStyle}"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="AM"
                                                   Foreground="#1F2937"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="MenuUserEmail"
                                                   Text="{Binding Authenticator.CurrentUserResponse.Email}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="#111827"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="160"/>
                                        <TextBlock x:Name="MenuUserRole"
                                                   Text="مدير النظام"
                                                   FontSize="11"
                                                   Foreground="#6B7280"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Button Style="{StaticResource HeaderPopupMenuItemStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👤"
                                               FontSize="14"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="الملف الشخصي"
                                               FontSize="13"
                                               Foreground="#111827"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Border Height="1"
                                    Background="#E5E7EB"
                                    Margin="6,6"/>

                            <Button Style="{StaticResource HeaderPopupDangerMenuItemStyle}"
                                    Command="{Binding LogoutCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚪"
                                               FontSize="14"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="تسجيل الخروج"
                                               FontSize="13"
                                               Foreground="#EF4444"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Popup>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>