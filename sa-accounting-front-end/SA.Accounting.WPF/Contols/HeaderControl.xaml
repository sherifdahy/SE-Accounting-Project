<UserControl x:Class="SA.Accounting.WPF.Contols.HeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="64"
             d:DesignWidth="1000"
             FlowDirection="RightToLeft">


    <Border Background="White"
            BorderBrush="#E5E7EB"
            BorderThickness="0,0,0,1"
            Padding="24,0"
            Height="64">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Page Title -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding PageTitle}"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#111827"/>
            </StackPanel>

            <!-- User Menu -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <Button x:Name="UserMenuBtn"
                        Style="{StaticResource HeaderAvatarButtonStyle}"
                        Command="{Binding ToggleUserMenuCommand}">
                    <TextBlock Text="{Binding Authenticator.CurrentUserResponse.Email,
                               Converter={StaticResource NameToInitialsConverter}}"
                               Foreground="#1F2937"
                               FontSize="12"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Popup PlacementTarget="{Binding ElementName=UserMenuBtn}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       VerticalOffset="6"
                       IsOpen="{Binding IsUserMenuOpen, Mode=TwoWay}">

                    <Border Style="{StaticResource HeaderPopupContainerStyle}"
                            MinWidth="240">
                        <Border.Effect>
                            <DropShadowEffect Color="Black"
                                              Opacity="0.15"
                                              BlurRadius="20"
                                              Direction="270"
                                              ShadowDepth="4"/>
                        </Border.Effect>

                        <StackPanel>
                            <Border Style="{StaticResource HeaderUserInfoBoxStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Style="{StaticResource HeaderAvatarCircleStyle}"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Authenticator.CurrentUserResponse.Name,
                                                   Converter={StaticResource NameToInitialsConverter}}"
                                                   Foreground="#1F2937"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Authenticator.CurrentUserResponse.Email}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="#111827"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="160"/>
                                        <TextBlock Text="{Binding Authenticator.CurrentUserResponse.Role}"
                                                   FontSize="11"
                                                   Foreground="#6B7280"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Button Style="{StaticResource HeaderPopupMenuItemStyle}"
                                    Command="{Binding NavigateToProfileCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                                          Fill="#6B7280" 
                                          Width="16" Height="16"
                                          Stretch="Uniform" 
                                          Margin="0,0,8,0"/>

                                    <TextBlock Text="الملف الشخصي"
                                               FontSize="13"
                                               Foreground="#111827"/>
                                </StackPanel>
                            </Button>

                            <Border Height="1"
                                    Background="#E5E7EB"
                                    Margin="6,6"/>

                            <Button Style="{StaticResource HeaderPopupDangerMenuItemStyle}"
                                    Command="{Binding LogoutCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M16,17V14H9V10H16V7L21,12L16,17M14,2A2,2 0 0,1 16,4V6H14V4H5V20H14V18H16V20A2,2 0 0,1 14,22H5A2,2 0 0,1 3,20V4A2,2 0 0,1 5,2H14Z"
                                          Fill="#EF4444" 
                                          Width="16" Height="16"
                                          Stretch="Uniform" 
                                          Margin="0,0,8,0"/>
                                    <TextBlock Text="تسجيل الخروج"
                                               FontSize="13"
                                               Foreground="#EF4444"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Popup>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>