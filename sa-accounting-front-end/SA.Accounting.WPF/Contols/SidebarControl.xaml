<UserControl x:Class="SA.Accounting.WPF.Contols.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="240"
             xmlns:converters="clr-namespace:SA.Accounting.WPF.Converters"
             xmlns:consts="clr-namespace:SA.Accounting.Core.Consts;assembly=SA.Accounting.Core"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <converters:PermissionToVisibilityConverter x:Key="PermissionToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="#1C2536">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo -->
            <StackPanel Grid.Row="0" Margin="16,20,16,16">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Style="{StaticResource SidebarLogoBoxStyle}" Margin="0,0,10,0">
                        <TextBlock Text="💼"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Saber Eid"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Accounting System"
                                   FontSize="11"
                                   Foreground="#9CA3AF"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Menu -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,4">

                <StackPanel x:Name="SidebarContent">

                    <!-- Home -->
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            x:Name="HomePageBtn"
                            Content="🏠  الصفحة الرئيسية"
                            Tag="Selected"/>

                    <!-- Companies -->
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            x:Name="CompanyPageBtn"
                            Content="🏢  الشركات"
                            Visibility="{Binding UserPermissions,
                                Converter={StaticResource PermissionToVisibilityConverter},
                                ConverterParameter={x:Static consts:Permissions.CompaniesRead}}"/>

                    <!-- Platforms -->
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            x:Name="PlatfromsBtn"
                            Content="🏛️  المنظمات"
                            Visibility="{Binding UserPermissions,
                                Converter={StaticResource PermissionToVisibilityConverter},
                                ConverterParameter={x:Static consts:Permissions.PlatformsRead}}"/>

                    <!-- Users -->
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            x:Name="UsersBtn"
                            Content="👥  المستخدمين"
                            Visibility="{Binding UserPermissions,
                                Converter={StaticResource PermissionToVisibilityConverter},
                                ConverterParameter={x:Static consts:Permissions.UsersRead}}"/>

                    <!-- Transactions -->
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            x:Name="TransactionsBtn"
                            Content="💰  العهد"
                            Visibility="{Binding UserPermissions,
                                Converter={StaticResource PermissionToVisibilityConverter},
                                ConverterParameter={x:Static consts:Permissions.TransactionsRead}}"/>

                    <!-- Reports -->
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            x:Name="ReportsBtn"
                            Content="📄  التقارير"
                            Visibility="{Binding UserPermissions,
                                Converter={StaticResource PermissionToVisibilityConverter},
                                ConverterParameter={x:Static consts:Permissions.ReportsRead}}"/>

                    <!-- Settings -->
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            x:Name="SettingsBtn"
                            Content="⚙️  الإعدادات"
                            Margin="8,6,8,1"
                            Visibility="{Binding UserPermissions,
                                Converter={StaticResource PermissionToVisibilityConverter},
                                ConverterParameter={x:Static consts:Permissions.SettingsRead}}"/>

                </StackPanel>
            </ScrollViewer>

            <!-- User Info -->
            <Border Grid.Row="2"
                    Style="{StaticResource SidebarUserCardStyle}">
                <StackPanel Orientation="Horizontal">

                    <Border Style="{StaticResource SidebarAvatarCircleStyle}" Margin="0,0,8,0">
                        <TextBlock Text="👤"
                                   Foreground="White"
                                   FontSize="14"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="UserEmailTxt"
                                   Text="admin@example.com"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="140"/>

                        <TextBlock x:Name="UserRoleTxt"
                                   Text="مدير النظام"
                                   FontSize="10"
                                   Foreground="#9CA3AF"/>
                    </StackPanel>

                </StackPanel>
            </Border>

        </Grid>
    </Border>
</UserControl>