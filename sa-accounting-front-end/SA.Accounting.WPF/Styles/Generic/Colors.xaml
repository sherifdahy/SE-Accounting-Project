<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════ Brand ══════ -->
    <Color x:Key="PrimaryColorValue">#1A1F3A</Color>
    <Color x:Key="PrimaryHoverColorValue">#252B48</Color>
    <Color x:Key="PrimaryPressedColorValue">#111827</Color>
    <Color x:Key="AccentColorValue">#FFB800</Color>
    <Color x:Key="AccentHoverColorValue">#E5A600</Color>
    <Color x:Key="AccentPressedColorValue">#CC9200</Color>

    <SolidColorBrush x:Key="PrimaryBrush"        Color="{StaticResource PrimaryColorValue}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush"    Color="{StaticResource PrimaryHoverColorValue}"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush"  Color="{StaticResource PrimaryPressedColorValue}"/>
    <SolidColorBrush x:Key="AccentBrush"          Color="{StaticResource AccentColorValue}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"     Color="{StaticResource AccentHoverColorValue}"/>
    <SolidColorBrush x:Key="AccentPressedBrush"   Color="{StaticResource AccentPressedColorValue}"/>

    <!-- ══════ Semantic ══════ -->
    <SolidColorBrush x:Key="SuccessBrush"         Color="#10B981"/>
    <SolidColorBrush x:Key="SuccessLightBrush"    Color="#D1FAE5"/>
    <SolidColorBrush x:Key="ErrorBrush"           Color="#EF4444"/>
    <SolidColorBrush x:Key="ErrorHoverBrush"      Color="#DC2626"/>
    <SolidColorBrush x:Key="ErrorPressedBrush"    Color="#B91C1C"/>
    <SolidColorBrush x:Key="ErrorLightBrush"      Color="#FEE2E2"/>
    <SolidColorBrush x:Key="WarningBrush"         Color="#F59E0B"/>
    <SolidColorBrush x:Key="WarningLightBrush"    Color="#FEF3C7"/>
    <SolidColorBrush x:Key="InfoBrush"            Color="#3B82F6"/>
    <SolidColorBrush x:Key="InfoLightBrush"       Color="#EFF6FF"/>
    <SolidColorBrush x:Key="InfoDarkBrush"        Color="#1E40AF"/>
    <SolidColorBrush x:Key="InfoMediumBrush"      Color="#DBEAFE"/>

    <!-- ══════ Text ══════ -->
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#111827"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#374151"/>
    <SolidColorBrush x:Key="TextMutedBrush"       Color="#6B7280"/>
    <SolidColorBrush x:Key="TextPlaceholderBrush" Color="#9CA3AF"/>

    <!-- ══════ Surface / Background ══════ -->
    <SolidColorBrush x:Key="SurfaceBrush"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush"    Color="#F9FAFB"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"      Color="#F3F4F6"/>
    <SolidColorBrush x:Key="InputBackgroundBrush"  Color="#F9FAFB"/>
    <SolidColorBrush x:Key="SelectedBgBrush"      Color="#F8FAFF"/>

    <!-- ══════ Border ══════ -->
    <SolidColorBrush x:Key="BorderDefaultBrush"   Color="#E5E7EB"/>
    <SolidColorBrush x:Key="BorderHoverBrush"     Color="#D1D5DB"/>
    <SolidColorBrush x:Key="BorderFocusBrush"     Color="#3B82F6"/>

    <!-- ══════ Sidebar ══════ -->
    <SolidColorBrush x:Key="SidebarBgBrush"       Color="#1F2937"/>
    <SolidColorBrush x:Key="SidebarTextBrush"     Color="#9CA3AF"/>
    <SolidColorBrush x:Key="SidebarTextHoverBrush" Color="#D1D5DB"/>

</ResourceDictionary>