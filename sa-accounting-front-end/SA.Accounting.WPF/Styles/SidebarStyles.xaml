<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Sidebar Main Buttons -->
    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="#9CA3AF"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="8,1"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#2D3748"/>
                            <Setter Property="Foreground" Value="#E5E7EB"/>
                        </Trigger>

                        <Trigger Property="Tag" Value="Selected">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#FFB800"/>
                            <Setter Property="Foreground" Value="#1F2937"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar user card -->
    <Style x:Key="SidebarUserCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#2D3748"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Margin" Value="10,10,10,12"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <!-- Sidebar active company card -->
    <Style x:Key="SidebarActiveCompanyCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#2D3748"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <!-- Sidebar icon circle -->
    <Style x:Key="SidebarAvatarCircleStyle" TargetType="Border">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Background" Value="#374151"/>
    </Style>

    <!-- Sidebar logo box -->
    <Style x:Key="SidebarLogoBoxStyle" TargetType="Border">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="#FFB800"/>
    </Style>

    <!-- Sidebar status badge -->
    <Style x:Key="SidebarStatusBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="#10B981"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="6,2"/>
    </Style>

</ResourceDictionary>