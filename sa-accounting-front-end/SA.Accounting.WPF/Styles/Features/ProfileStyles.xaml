<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════ Profile Avatar (Large) ══════ -->
    <Style x:Key="ProfileAvatarLg" TargetType="Border">
        <Setter Property="Width" Value="72"/>
        <Setter Property="Height" Value="72"/>
        <Setter Property="CornerRadius" Value="36"/>
        <Setter Property="Margin" Value="0,0,16,0"/>
    </Style>

    <!-- ══════ Profile Avatar Text ══════ -->
    <Style x:Key="ProfileAvatarText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ══════ Sidebar Nav Item (Default) ══════ -->
    <Style x:Key="ProfileNavItem" TargetType="Border">
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- ══════ Sidebar Nav Text (Default) ══════ -->
    <Style x:Key="ProfileNavText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ══════ Sidebar Nav Icon ══════ -->
    <Style x:Key="ProfileNavIcon" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ══════ Profile Section Title ══════ -->
    <Style x:Key="ProfileSectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ══════ Profile Section Icon ══════ -->
    <Style x:Key="ProfileSectionIcon" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ══════ Disabled Input (Read Only) ══════ -->
    <Style x:Key="InputReadOnly" TargetType="TextBlock">
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="InputReadOnlyBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}"/>
        <Setter Property="Height" Value="{StaticResource InputHeightLg}"/>
        <Setter Property="Padding" Value="10,0"/>
    </Style>

</ResourceDictionary>