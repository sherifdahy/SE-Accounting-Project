<!-- Styles/UserPermissionsStyles.xaml -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════ Progress Bar ══════ -->
    <Style x:Key="PermissionProgressBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="6"/>
        <Setter Property="Width" Value="80"/>
        <Setter Property="Minimum" Value="0"/>
        <Setter Property="Maximum" Value="1"/>
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Height="{TemplateBinding Height}"/>
                        <Border x:Name="PART_Track"/>
                        <Border x:Name="PART_Indicator"
                                Background="{TemplateBinding Foreground}"
                                CornerRadius="3"
                                Height="{TemplateBinding Height}"
                                HorizontalAlignment="Left"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════ Group Expander Toggle Button ══════ -->
    <Style x:Key="ExpanderToggle" TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            Padding="8,10">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════ Permission Checkbox Card ══════ -->
    <Style x:Key="PermissionCheckCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Margin" Value="0,0,8,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Background" Value="{StaticResource InfoLightBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource InfoBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ══════ Group Row ══════ -->
    <Style x:Key="GroupRowBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <!-- ══════ Modern Checkbox ══════ -->
    <Style x:Key="ModernCheckBox" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="CheckBorder"
                                Width="16" Height="16"
                                CornerRadius="4"
                                BorderThickness="1.5"
                                BorderBrush="{StaticResource BorderHoverBrush}"
                                Background="{StaticResource SurfaceBrush}">
                            <TextBlock x:Name="CheckMark"
                                       Text="✓"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Border>

                        <ContentPresenter Grid.Column="1"
                                          Margin="6,0,0,0"
                                          VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckBorder" Property="Background"
                                    Value="{StaticResource InfoBrush}"/>
                            <Setter TargetName="CheckBorder" Property="BorderBrush"
                                    Value="{StaticResource InfoBrush}"/>
                            <Setter TargetName="CheckMark" Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckBorder" Property="BorderBrush"
                                    Value="{StaticResource InfoBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════ Sticky Footer ══════ -->
    <Style x:Key="StickyFooter" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Padding" Value="20,12"/>
    </Style>

    <!-- ══════ Search Box ══════ -->
    <Style x:Key="SearchInput" TargetType="TextBox" BasedOn="{StaticResource TextBoxDefault}">
        <Setter Property="Height" Value="{StaticResource InputHeightLg}"/>
        <Setter Property="Padding" Value="28,0,10,0"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}"/>
    </Style>

</ResourceDictionary>