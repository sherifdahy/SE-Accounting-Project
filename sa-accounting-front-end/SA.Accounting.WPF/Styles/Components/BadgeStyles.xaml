<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="BadgeBase" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}"/>
        <Setter Property="Padding" Value="{StaticResource BadgePadding}"/>
        <Setter Property="Margin" Value="6,0,0,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="BadgeWarning" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
        <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
    </Style>

    <Style x:Key="BadgeSuccess" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
        <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
    </Style>

    <Style x:Key="BadgeDark" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}"/>
        <Setter Property="Padding" Value="8,2"/>
        <Setter Property="Margin" Value="10,0,0,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>