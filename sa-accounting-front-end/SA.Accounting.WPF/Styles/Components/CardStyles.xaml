<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════ Base Card ══════ -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius2Xl}"/>
        <Setter Property="Padding" Value="{StaticResource CardPadding}"/>
    </Style>

    <!-- ══════ Clickable Card ══════ -->
    <Style x:Key="CardClickable" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#818CF8"/>
                <Setter Property="Background" Value="#FAFAFE"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#6366F1" Opacity="0.08"
                                          BlurRadius="12" ShadowDepth="2"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ══════ Row Card ══════ -->
    <Style x:Key="CardRow" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- ══════ Highlight Card (Owner/Warning) ══════ -->
    <Style x:Key="CardHighlight" TargetType="Border">
        <Setter Property="Background" Value="#FFFBEB"/>
        <Setter Property="BorderBrush" Value="#FDE68A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}"/>
        <Setter Property="Padding" Value="14"/>
    </Style>


    <!-- ══════ Stat Card ══════ -->
    <Style x:Key="StatCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" Opacity="0.05"
                              BlurRadius="8" ShadowDepth="2" Direction="270"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════ Stat Icon Box ══════ -->
    <Style x:Key="StatIconBox" TargetType="Border">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- ══════ Content Card (Table wrapper) ══════ -->
    <Style x:Key="ContentCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" Opacity="0.05"
                              BlurRadius="8" ShadowDepth="2" Direction="270"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════ Table Wrapper ══════ -->
    <Style x:Key="TableBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <!-- ══════ Table Header ══════ -->
    <Style x:Key="TableHeaderBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- ══════ Table Row ══════ -->
    <Style x:Key="TableRowBorder" TargetType="Border">
        <Setter Property="Padding" Value="20,14"/>
        <Setter Property="BorderBrush" Value="{StaticResource SurfaceHoverBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ══════ Section Card ══════ -->
    <Style x:Key="SectionCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Margin" Value="0,0,0,14"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" Opacity="0.04"
                              BlurRadius="6" ShadowDepth="1"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════ Section Indicator Bar ══════ -->
    <Style x:Key="SectionIndicator" TargetType="Border">
        <Setter Property="Width" Value="3"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <!-- ══════ Empty State Card ══════ -->
    <Style x:Key="EmptyStateCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}"/>
        <Setter Property="Padding" Value="16,20"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
        <Setter Property="Visibility" Value="Collapsed"/>
    </Style>

    <!-- ══════ Info Card (Display pages) ══════ -->
    <Style x:Key="InfoCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" Opacity="0.03"
                              BlurRadius="6" ShadowDepth="1"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════ Info Icon Box ══════ -->
    <Style x:Key="InfoIconBox" TargetType="Border">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}"/>
    </Style>
</ResourceDictionary>