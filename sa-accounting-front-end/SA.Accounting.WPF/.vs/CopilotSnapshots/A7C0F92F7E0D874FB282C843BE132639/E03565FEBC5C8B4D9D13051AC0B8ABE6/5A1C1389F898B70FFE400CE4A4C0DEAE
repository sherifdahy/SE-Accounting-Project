<Window
    FlowDirection="RightToLeft"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:SA.Accounting.WPF.Portals.SystemAdministration.Windows"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" 
    x:Class="SA.Accounting.WPF.Portals.SystemAdministration.Windows.MainWindow"
    mc:Ignorable="d"
    WindowState="Maximized"
    Loaded="Window_Loaded"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="Saber Eid Accounting" 
    Height="450" 
    Width="800"
    Background="#F3F4F6">

    <Window.Resources>

        <!-- ✅ Sidebar Button Style - Dark Theme -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="8,1"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2D3748"/>
                                <Setter Property="Foreground" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFB800"/>
                                <Setter Property="Foreground" Value="#1F2937"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════ -->
        <!-- SIDEBAR (Full Height) -->
        <!-- ═══════════════════════════════════════════ -->

        <Border Grid.Column="0" 
                Background="#1C2536">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo Section -->
                <StackPanel Grid.Row="0" Margin="16,20,16,16">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <!-- Logo Icon -->
                        <Border Width="40" 
                                Height="40" 
                                CornerRadius="10" 
                                Background="#FFB800"
                                Margin="0,0,10,0">
                            <TextBlock Text="💼" 
                                       FontSize="20"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- App Name -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Saber Eid" 
                                       FontSize="15" 
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Accounting System" 
                                       FontSize="11" 
                                       Foreground="#9CA3AF"
                                       Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Active Company Card -->
                    <Border x:Name="ActiveCompanyCard"
                            Background="#2D3748"
                            CornerRadius="10"
                            Padding="12"
                            Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock x:Name="ActiveCompanyName"
                                           Text="الشركة النشطة" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Right"/>
                                <Border Background="#10B981"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="نشط" 
                                               FontSize="10" 
                                               FontWeight="Bold"
                                               Foreground="White"/>
                                </Border>
                            </Grid>

                            <TextBlock x:Name="ActiveCompanyDetails"
                                       Text="رقم التسجيل الضريبي" 
                                       FontSize="11" 
                                       Foreground="#9CA3AF"
                                       Margin="0,0,0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="العملاء" 
                                               FontSize="10" 
                                               Foreground="#9CA3AF"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="الموردين" 
                                               FontSize="10" 
                                               Foreground="#9CA3AF"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Menu Items -->
                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto"
                              Padding="0,4">
                    <StackPanel x:Name="SidebarContent">

                        <!-- الرئيسية -->
                        <Button Style="{StaticResource SidebarButtonStyle}" 
                                x:Name="HomePageBtn"
                                Content="🏠  الصفحة الرئيسية" 
                                Click="HomePageBtn_Click"
                                Tag="Selected"/>

                        <!-- الشركات -->
                        <Button Style="{StaticResource SidebarButtonStyle}" 
                                x:Name="CompanyPageBtn"
                                Content="🏢  الشركات" 
                                Click="CompanyPageBtn_Click"/>

                        <!-- المنظمات -->
                        <Button Style="{StaticResource SidebarButtonStyle}" 
                                x:Name="PlatfromsBtn"
                                Content="🏛️  المنظمات" 
                                Click="PlatfromsBtn_Click"/>

                        <!-- الموظفين -->
                        <Button Style="{StaticResource SidebarButtonStyle}" 
                                x:Name="UsersBtn"
                                Content="👥  المستخدمين" 
                                Click="UsersBtn_Click"/>

                        <!-- العهد -->
                        <Button Style="{StaticResource SidebarButtonStyle}" 
                                x:Name="TransactionsBtn"
                                Content="💰  العهد" 
                                Click="TransactionsBtn_Click"/>

                        <!-- التقارير -->
                        <Button Style="{StaticResource SidebarButtonStyle}" 
                                x:Name="ReportsBtn"
                                Content="📄  التقارير"/>

                        <!-- الإعدادات -->
                        <Button x:Name="SettingsBtn" 
                                Style="{StaticResource SidebarButtonStyle}" 
                                Content="⚙️  الإعدادات" 
                                Click="SettingsBtn_Click"
                                Margin="8,6,8,1"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- User Info at Bottom -->
                <Border Grid.Row="2"
                        Background="#2D3748"
                        Padding="12,10"
                        Margin="10,10,10,12"
                        CornerRadius="8"
                        Cursor="Hand"
                        MouseDown="UserInfoBottom_Click">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" 
                                Height="32" 
                                CornerRadius="16" 
                                Background="#374151"
                                Margin="0,0,8,0">
                            <TextBlock Text="👤" 
                                       Foreground="White" 
                                       FontSize="14"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="UserEmailTxt"
                                       Text="admin@example.com" 
                                       FontSize="12" 
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="140"/>
                            <TextBlock x:Name="UserRoleTxt"
                                       Text="مدير النظام" 
                                       FontSize="10" 
                                       Foreground="#9CA3AF"
                                       Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- MAIN AREA (Header + Content) -->
        <!-- ═══════════════════════════════════════════ -->

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- WHITE HEADER -->
            <Border Grid.Row="0" 
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="0,0,0,1"
                    Padding="24,0"
                    Height="64">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Page Title -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitleHeader"
                                   Text="لوحة التحكم" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                        <TextBlock x:Name="PageSubtitleHeader"
                                   Text="نظام إدارة المحاسبة" 
                                   FontSize="12" 
                                   Foreground="#6B7280"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- Right: Notifications + User -->
                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal" 
                                VerticalAlignment="Center">

                        <!-- Notifications Button -->
                        <Button Width="36" 
                                Height="36" 
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="8">
                                                    <Grid>
                                                        <TextBlock Text="🔔" 
                                                                   FontSize="18"
                                                                   HorizontalAlignment="Center" 
                                                                   VerticalAlignment="Center"/>
                                                        <!-- Notification Badge -->
                                                        <Border Width="7" 
                                                                Height="7" 
                                                                CornerRadius="4" 
                                                                Background="#EF4444"
                                                                HorizontalAlignment="Right" 
                                                                VerticalAlignment="Top"
                                                                Margin="0,7,7,0"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#F3F4F6"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- User Avatar Button -->
                        <Button x:Name="UserMenuBtn"
                                Width="36" 
                                Height="36" 
                                Background="#F3F4F6"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="UserMenuBtn_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="18">
                                                    <TextBlock Text="AM" 
                                                               Foreground="#1F2937" 
                                                               FontSize="12"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- User Menu Popup -->
                        <Popup x:Name="UserMenuPopup"
                               PlacementTarget="{Binding ElementName=UserMenuBtn}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               VerticalOffset="6">

                            <Border Background="White"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="6"
                                    MinWidth="240">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" 
                                                      Opacity="0.15" 
                                                      BlurRadius="20" 
                                                      Direction="270"
                                                      ShadowDepth="4"/>
                                </Border.Effect>

                                <StackPanel>
                                    <!-- User Info -->
                                    <Border Background="#F9FAFB" 
                                            Padding="12,10"
                                            CornerRadius="8"
                                            Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="36" 
                                                    Height="36" 
                                                    CornerRadius="18" 
                                                    Background="#E5E7EB"
                                                    Margin="0,0,10,0">
                                                <TextBlock Text="AM" 
                                                           Foreground="#1F2937"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock x:Name="MenuUserEmail"
                                                           Text="admin@example.com" 
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           Foreground="#111827"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="160"/>
                                                <TextBlock x:Name="MenuUserRole"
                                                           Text="مدير النظام" 
                                                           FontSize="11"
                                                           Foreground="#6B7280"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Profile Button -->
                                    <Button Click="ProfileMenuItem_Click"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Padding="12,9"
                                            HorizontalContentAlignment="Right"
                                            Margin="0,1">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#F3F4F6"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="👤" 
                                                       FontSize="14" 
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="الملف الشخصي" 
                                                       FontSize="13"
                                                       Foreground="#111827"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Separator -->
                                    <Border Height="1" 
                                            Background="#E5E7EB"
                                            Margin="6,6"/>

                                    <!-- Logout Button -->
                                    <Button Click="LogoutBtn_Click"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Padding="12,9"
                                            HorizontalContentAlignment="Right"
                                            Margin="0,1">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#FEE2E2"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🚪" 
                                                       FontSize="14" 
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="تسجيل الخروج" 
                                                       FontSize="13"
                                                       Foreground="#EF4444"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Border Grid.Row="1" 
                    Background="#F9FAFB">
                <ContentControl Content="{Binding Navigator.CurrentViewModel}"/>
            </Border>

        </Grid>

    </Grid>
</Window>