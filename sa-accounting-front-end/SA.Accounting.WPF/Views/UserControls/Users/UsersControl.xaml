<UserControl
    FlowDirection="RightToLeft"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SA.Accounting.WPF.Views.UserControls.Users"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    x:Class="SA.Accounting.WPF.Views.UserControls.Users.UsersControl"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="900"
    Loaded="UserControl_Loaded"
    Background="#F9FAFB">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>

        <!-- ═══ Layer 1: القائمة ═══ -->
        <Grid x:Name="ListPanel">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,20,24,32">

                    <!-- ═══════════════════════════════════════ -->
                    <!-- ═══ 📊 Statistics Cards ═══════════════ -->
                    <!-- ═══════════════════════════════════════ -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- إجمالي المستخدمين -->
                        <Border Grid.Column="0" Background="White"
                                CornerRadius="10" Padding="16" Margin="0,0,8,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.05"
                                                  BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="إجمالي المستخدمين" FontSize="12"
                                               Foreground="#6B7280" HorizontalAlignment="Right"/>
                                    <Border Background="#EFF6FF" Width="32" Height="32"
                                            CornerRadius="8" HorizontalAlignment="Left">
                                        <TextBlock Text="👥" FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding TotalUsers}" FontSize="26"
                                           FontWeight="Bold" Foreground="#111827" Margin="0,0,0,3"/>
                                <TextBlock Text="مستخدم مسجل" FontSize="11" Foreground="#10B981"/>
                            </StackPanel>
                        </Border>

                        <!-- المستخدمين النشطين -->
                        <Border Grid.Column="1" Background="White"
                                CornerRadius="10" Padding="16" Margin="0,0,8,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.05"
                                                  BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="المستخدمين النشطين" FontSize="12"
                                               Foreground="#6B7280" HorizontalAlignment="Right"/>
                                    <Border Background="#D1FAE5" Width="32" Height="32"
                                            CornerRadius="8" HorizontalAlignment="Left">
                                        <TextBlock Text="✅" FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding TotalActiveUsers}" FontSize="26"
                                           FontWeight="Bold" Foreground="#111827" Margin="0,0,0,3"/>
                                <TextBlock Text="مستخدم نشط" FontSize="11" Foreground="#10B981"/>
                            </StackPanel>
                        </Border>

                        <!-- المستخدمين المحذوفين -->
                        <Border Grid.Column="2" Background="White"
                                CornerRadius="10" Padding="16" Margin="0,0,8,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.05"
                                                  BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="المستخدمين المحذوفين" FontSize="12"
                                               Foreground="#6B7280" HorizontalAlignment="Right"/>
                                    <Border Background="#FEE2E2" Width="32" Height="32"
                                            CornerRadius="8" HorizontalAlignment="Left">
                                        <TextBlock Text="🗑️" FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding TotalDeletedUsers}" FontSize="26"
                                           FontWeight="Bold" Foreground="#111827" Margin="0,0,0,3"/>
                                <TextBlock Text="مستخدم محذوف" FontSize="11" Foreground="#DC2626"/>
                            </StackPanel>
                        </Border>

                        <!-- المشرفين -->
                        <Border Grid.Column="3" Background="White"
                                CornerRadius="10" Padding="16">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.05"
                                                  BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="المشرفين" FontSize="12"
                                               Foreground="#6B7280" HorizontalAlignment="Right"/>
                                    <Border Background="#F3E8FF" Width="32" Height="32"
                                            CornerRadius="8" HorizontalAlignment="Left">
                                        <TextBlock Text="🛡️" FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding TotalAdmins}" FontSize="26"
                                           FontWeight="Bold" Foreground="#111827" Margin="0,0,0,3"/>
                                <TextBlock Text="مشرف" FontSize="11" Foreground="#7C3AED"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ═══════════════════════════════════════════ -->
                    <!-- ═══ 📋 Users Section ═════════════════════ -->
                    <!-- ═══════════════════════════════════════════ -->
                    <Border Background="White" CornerRadius="10" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.05"
                                              BlurRadius="8" ShadowDepth="2" Direction="270"/>
                        </Border.Effect>

                        <StackPanel>

                            <!-- ── Header: عنوان + زر إضافة ── -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="جميع المستخدمين" FontSize="16"
                                               FontWeight="Bold" Foreground="#111827"/>
                                    <TextBlock Text="إدارة ومتابعة معلومات المستخدمين"
                                               FontSize="12" Foreground="#6B7280"
                                               Margin="0,3,0,0"/>
                                </StackPanel>

                                <telerik:RadButton Grid.Column="1"
                                                   Content="+ إضافة مستخدم"
                                                   Click="AddUserButton_Click"
                                                   Style="{StaticResource ModernButtonStyle}"
                                                   Width="140" Height="36" FontSize="13"/>
                            </Grid>

                            <!-- ── Search + Filter ── -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <telerik:RadWatermarkTextBox
                                    Grid.Column="0"
                                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                    WatermarkContent="ابحث عن مستخدم..."
                                    Style="{StaticResource ModernInputStyle}"
                                    Height="38" FontSize="13" Width="300"
                                    Margin="0,0,10,0"/>

                                <telerik:RadComboBox
                                    Grid.Column="1"
                                    Style="{StaticResource ModernComboBoxStyle}"
                                    Width="180" Height="38" SelectedIndex="0"
                                    SelectionChanged="FilterComboBox_SelectionChanged">
                                    <telerik:RadComboBoxItem Content="النشطين فقط" Tag="false"/>
                                    <telerik:RadComboBoxItem Content="جميع المستخدمين" Tag="true"/>
                                </telerik:RadComboBox>
                            </Grid>

                            <!-- ═══════════════════════════════════════ -->
                            <!-- ═══ Table المستخدمين ══════════════════ -->
                            <!-- ═══════════════════════════════════════ -->
                            <Border CornerRadius="10"
                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                    ClipToBounds="True">

                                <StackPanel>

                                    <!-- Table Header -->
                                    <Border Background="#F8FAFC"
                                            Padding="20,12"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="0.8*"/>
                                                <ColumnDefinition Width="0.8*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="130"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="#"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#64748B"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="المستخدم"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#64748B"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="البريد الإلكتروني"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#64748B"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="رقم الهاتف"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#64748B"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="الدور"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#64748B"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="الحالة"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#64748B"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="6" Text="إجراءات"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#64748B"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- User Rows -->
                                    <ItemsControl ItemsSource="{Binding FilteredUsers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="20,14"
                                                        BorderBrush="#F1F5F9"
                                                        BorderThickness="0,0,0,1"
                                                        Cursor="Hand">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background"
                                                                    Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver"
                                                                         Value="True">
                                                                    <Setter Property="Background"
                                                                            Value="#F8FAFC"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="0.8*"/>
                                                            <ColumnDefinition Width="0.8*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="130"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- ID -->
                                                        <TextBlock Grid.Column="0"
                                                                   FontSize="12"
                                                                   Foreground="#94A3B8"
                                                                   VerticalAlignment="Center">
                                                            <Run Text="#"/>
                                                            <Run Text="{Binding Id, Mode=OneWay}"/>
                                                        </TextBlock>

                                                        <!-- المستخدم: أيقونة + اسم -->
                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Center">

                                                            <Border Width="40" Height="40"
                                                                    CornerRadius="20"
                                                                    Margin="0,0,12,0"
                                                                    ClipToBounds="True"
                                                                    BorderBrush="#E2E8F0"
                                                                    BorderThickness="1">
                                                                <Border.Background>
                                                                    <LinearGradientBrush
                                                                        StartPoint="0,0"
                                                                        EndPoint="1,1">
                                                                        <GradientStop Color="#EEF2FF"
                                                                                      Offset="0"/>
                                                                        <GradientStop Color="#E0E7FF"
                                                                                      Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Border.Background>

                                                                <TextBlock Text="👤" FontSize="18"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Opacity="0.7"/>
                                                            </Border>

                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontSize="14"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#1E293B"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxWidth="160"
                                                                           ToolTip="{Binding Name}"/>
                                                                <TextBlock Text="{Binding SSN}"
                                                                           FontSize="11"
                                                                           Foreground="#94A3B8"
                                                                           Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <!-- البريد الإلكتروني -->
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Email}"
                                                                   FontSize="12"
                                                                   Foreground="#6366F1"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding Email}"
                                                                   FlowDirection="LeftToRight"
                                                                   Opacity="0.85"/>

                                                        <!-- رقم الهاتف -->
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding PhoneNumber}"
                                                                   FontSize="12"
                                                                   Foreground="#475569"
                                                                   VerticalAlignment="Center"
                                                                   FlowDirection="LeftToRight"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding PhoneNumber}"/>

                                                        <!-- الدور -->
                                                        <Border Grid.Column="4"
                                                                CornerRadius="6"
                                                                Padding="8,4"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background"
                                                                            Value="#F1F5F9"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger
                                                                            Binding="{Binding Role}"
                                                                            Value="Admin">
                                                                            <Setter
                                                                                Property="Background"
                                                                                Value="#F3E8FF"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Role}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground"
                                                                                Value="#64748B"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger
                                                                                Binding="{Binding Role}"
                                                                                Value="Admin">
                                                                                <Setter
                                                                                    Property="Foreground"
                                                                                    Value="#7C3AED"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>

                                                        <!-- الحالة -->
                                                        <Border Grid.Column="5"
                                                                CornerRadius="20"
                                                                Padding="10,4"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background"
                                                                            Value="#ECFDF5"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger
                                                                            Binding="{Binding IsDeleted}"
                                                                            Value="True">
                                                                            <Setter
                                                                                Property="Background"
                                                                                Value="#FEF2F2"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text"
                                                                                Value="نشط"/>
                                                                        <Setter Property="Foreground"
                                                                                Value="#059669"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger
                                                                                Binding="{Binding IsDeleted}"
                                                                                Value="True">
                                                                                <Setter
                                                                                    Property="Text"
                                                                                    Value="محذوف"/>
                                                                                <Setter
                                                                                    Property="Foreground"
                                                                                    Value="#DC2626"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>

                                                        <!-- أزرار الإجراءات -->
                                                        <StackPanel Grid.Column="6"
                                                                    Orientation="Horizontal"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center">

                                                            <!-- تعديل -->
                                                            <Button ToolTip="تعديل"
                                                                    Command="{Binding DataContext.UpdateUserCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Cursor="Hand"
                                                                    Margin="0,0,4,0">
                                                                <Button.Template>
                                                                    <ControlTemplate
                                                                        TargetType="Button">
                                                                        <Border x:Name="Bd"
                                                                                Width="32"
                                                                                Height="32"
                                                                                CornerRadius="8"
                                                                                Background="Transparent">
                                                                            <TextBlock Text="✏️"
                                                                                       FontSize="13"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger
                                                                                Property="IsMouseOver"
                                                                                Value="True">
                                                                                <Setter
                                                                                    TargetName="Bd"
                                                                                    Property="Background"
                                                                                    Value="#EEF2FF"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>

                                                            <!-- حذف -->
                                                            <Button ToolTip="حذف"
                                                                    Command="{Binding DataContext.DeleteUserCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Cursor="Hand">
                                                                <Button.Template>
                                                                    <ControlTemplate
                                                                        TargetType="Button">
                                                                        <Border x:Name="Bd"
                                                                                Width="32"
                                                                                Height="32"
                                                                                CornerRadius="8"
                                                                                Background="Transparent">
                                                                            <TextBlock Text="🗑️"
                                                                                       FontSize="13"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger
                                                                                Property="IsMouseOver"
                                                                                Value="True">
                                                                                <Setter
                                                                                    TargetName="Bd"
                                                                                    Property="Background"
                                                                                    Value="#FEF2F2"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Empty State -->
                                    <Border Padding="0,50">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding HasNoUsers}"
                                                        Value="True">
                                                        <Setter Property="Visibility"
                                                                Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Background="#F1F5F9"
                                                    Width="72" Height="72"
                                                    CornerRadius="20"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,0,0,16">
                                                <TextBlock Text="👥" FontSize="32"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Opacity="0.6"/>
                                            </Border>
                                            <TextBlock Text="لا يوجد مستخدمين"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="#475569"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,6"/>
                                            <TextBlock
                                                Text="اضغط على + إضافة مستخدم للبدء"
                                                FontSize="12" Foreground="#94A3B8"
                                                HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </Border>

                            <!-- Pagination -->
                            <TextBlock Text="{Binding PaginationInfo}"
                                       FontSize="12" Foreground="#6B7280"
                                       HorizontalAlignment="Left"
                                       Margin="0,16,0,0"/>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══ Layer 2: الشاشة الفرعية ═══ -->
        <ContentControl x:Name="ChildContent" Visibility="Collapsed"/>

    </Grid>
</UserControl>