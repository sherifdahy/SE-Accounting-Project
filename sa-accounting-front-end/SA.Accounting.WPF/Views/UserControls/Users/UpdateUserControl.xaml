<UserControl
    FlowDirection="RightToLeft"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SA.Accounting.WPF.Views.UserControls.Users"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    x:Class="SA.Accounting.WPF.Views.UserControls.Users.UpdateUserControl"
    mc:Ignorable="d"
    d:DesignHeight="700"
    d:DesignWidth="900"
    Background="#F9FAFB">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>

        <!-- ═══ Loading Overlay ═══ -->
        <Border Background="#F9FAFB" Panel.ZIndex="10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <telerik:RadBusyIndicator IsBusy="True"
                                          BusyContent="جاري تحميل البيانات..."
                                          DisplayAfter="0:0:0"/>
            </StackPanel>
        </Border>

        <!-- ═══ Form Content ═══ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,32" MaxWidth="700"
                        HorizontalAlignment="Center">

                <!-- ═══════════════════════════════════════ -->
                <!-- ═══ Header + زر الرجوع ════════════════ -->
                <!-- ═══════════════════════════════════════ -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Command="{Binding CancelCommand}"
                            Cursor="Hand" Margin="0,0,16,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Width="40" Height="40"
                                        CornerRadius="10" Background="White"
                                        BorderBrush="#E2E8F0" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.04"
                                                          BlurRadius="4" ShadowDepth="1"
                                                          Direction="270"/>
                                    </Border.Effect>
                                    <TextBlock Text="→" FontSize="18"
                                               FontWeight="Bold" Foreground="#475569"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd"
                                                Property="Background" Value="#F1F5F9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="تعديل بيانات المستخدم" FontSize="20"
                                   FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="قم بتعديل البيانات ثم اضغط حفظ التعديلات"
                                   FontSize="13" Foreground="#6B7280"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- ═══════════════════════════════════════ -->
                <!-- ═══ Form Card ═════════════════════════ -->
                <!-- ═══════════════════════════════════════ -->
                <Border Background="White" CornerRadius="12" Padding="32">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05"
                                          BlurRadius="10" ShadowDepth="3"
                                          Direction="270"/>
                    </Border.Effect>

                    <StackPanel>

                        <!-- ── Section: المعلومات الأساسية ── -->
                        <StackPanel Margin="0,0,0,24">
                            <Grid Margin="0,0,0,16">
                                <Border Background="#EFF6FF" Width="32" Height="32"
                                        CornerRadius="8" HorizontalAlignment="Right">
                                    <TextBlock Text="👤" FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="المعلومات الأساسية" FontSize="15"
                                           FontWeight="SemiBold" Foreground="#111827"
                                           Margin="0,0,44,0" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- الاسم -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="اسم المستخدم" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#374151"
                                           Margin="0,0,0,6"/>
                                <telerik:RadWatermarkTextBox
                                    Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                    WatermarkContent="أدخل اسم المستخدم..."
                                    Style="{StaticResource ModernInputStyle}"
                                    Height="42" FontSize="13"/>
                                <TextBlock Text="{Binding NameError}"
                                           FontSize="11" Foreground="#DC2626"
                                           Margin="0,4,0,0"
                                           />
                            </StackPanel>

                            <!-- البريد الإلكتروني -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="البريد الإلكتروني" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#374151"
                                           Margin="0,0,0,6"/>
                                <telerik:RadWatermarkTextBox
                                    Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                    WatermarkContent="example@mail.com"
                                    Style="{StaticResource ModernInputStyle}"
                                    Height="42" FontSize="13"
                                    FlowDirection="LeftToRight"/>
                                <TextBlock Text="{Binding EmailError}"
                                           FontSize="11" Foreground="#DC2626"
                                           Margin="0,4,0,0"
                                           />
                            </StackPanel>

                            <!-- الرقم القومي -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="الرقم القومي" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#374151"
                                           Margin="0,0,0,6"/>
                                <telerik:RadWatermarkTextBox
                                    Text="{Binding Ssn, UpdateSourceTrigger=PropertyChanged}"
                                    WatermarkContent="أدخل الرقم القومي..."
                                    Style="{StaticResource ModernInputStyle}"
                                    Height="42" FontSize="13"
                                    FlowDirection="LeftToRight"/>
                                <TextBlock Text="{Binding SsnError}"
                                           FontSize="11" Foreground="#DC2626"
                                           Margin="0,4,0,0"
                                          />
                            </StackPanel>
                        </StackPanel>

                        <!-- ── Separator ── -->
                        <Border Height="1" Background="#F1F5F9" Margin="0,0,0,24"/>

                        <!-- ── Section: بيانات الاتصال والأمان ── -->
                        <StackPanel Margin="0,0,0,24">
                            <Grid Margin="0,0,0,16">
                                <Border Background="#D1FAE5" Width="32" Height="32"
                                        CornerRadius="8" HorizontalAlignment="Right">
                                    <TextBlock Text="🔒" FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="بيانات الاتصال والأمان" FontSize="15"
                                           FontWeight="SemiBold" Foreground="#111827"
                                           Margin="0,0,44,0" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- رقم الهاتف -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="رقم الهاتف" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#374151"
                                           Margin="0,0,0,6"/>
                                <telerik:RadWatermarkTextBox
                                    Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                    WatermarkContent="05XXXXXXXX"
                                    Style="{StaticResource ModernInputStyle}"
                                    Height="42" FontSize="13"
                                    FlowDirection="LeftToRight"/>
                                <TextBlock Text="{Binding PhoneNumberError}"
                                           FontSize="11" Foreground="#DC2626"
                                           Margin="0,4,0,0"
                                         />
                            </StackPanel>

                            <!-- كلمة المرور (اختيارية) -->
                            <StackPanel Margin="0,0,0,16">
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="كلمة المرور" FontSize="13"
                                               FontWeight="SemiBold" Foreground="#374151"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="(اختياري - اتركه فارغاً لعدم التغيير)"
                                               FontSize="11" Foreground="#94A3B8"
                                               HorizontalAlignment="Left"/>
                                </Grid>
                                <telerik:RadWatermarkTextBox
                                    Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                    WatermarkContent="أدخل كلمة المرور الجديدة..."
                                    Style="{StaticResource ModernInputStyle}"
                                    Height="42" FontSize="13"
                                    FlowDirection="LeftToRight"/>
                                <TextBlock Text="{Binding PasswordError}"
                                           FontSize="11" Foreground="#DC2626"
                                           Margin="0,4,0,0"
                                      />
                            </StackPanel>

                            <!-- الدور -->
                            <StackPanel Margin="0,0,0,0">
                                <TextBlock Text="الدور" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#374151"
                                           Margin="0,0,0,6"/>
                                <telerik:RadComboBox
                                    Style="{StaticResource ModernComboBoxStyle}"
                                    Height="42" FontSize="13"
                                    SelectedValue="{Binding Role, Mode=TwoWay}"
                                    SelectedValuePath="Tag">
                                    <telerik:RadComboBoxItem Content="مشرف (Admin)"
                                                             Tag="Admin"/>
                                    <telerik:RadComboBoxItem Content="مستخدم (User)"
                                                             Tag="User"/>
                                    <telerik:RadComboBoxItem Content="محاسب (Accountant)"
                                                             Tag="Accountant"/>
                                    <telerik:RadComboBoxItem Content="مراجع (Auditor)"
                                                             Tag="Auditor"/>
                                </telerik:RadComboBox>
                                <TextBlock Text="{Binding RoleError}"
                                           FontSize="11" Foreground="#DC2626"
                                           Margin="0,4,0,0"
                                     />
                            </StackPanel>
                        </StackPanel>

                        <!-- ── Separator ── -->
                        <Border Height="1" Background="#F1F5F9" Margin="0,0,0,24"/>

                        <!-- ── Action Buttons ── -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- زر الإلغاء -->
                            <Button Grid.Column="1"
                                    Command="{Binding CancelCommand}"
                                    Cursor="Hand" Margin="0,0,10,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Height="42"
                                                Padding="24,0"
                                                CornerRadius="10"
                                                Background="White"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1">
                                            <TextBlock Text="إلغاء" FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#475569"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd"
                                                        Property="Background"
                                                        Value="#F9FAFB"/>
                                                <Setter TargetName="Bd"
                                                        Property="BorderBrush"
                                                        Value="#CBD5E1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- زر الحفظ -->
                            <Button Grid.Column="2"
                                    Command="{Binding SaveCommand}"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Height="42"
                                                Padding="24,0"
                                                CornerRadius="10">
                                            <Border.Background>
                                                <LinearGradientBrush
                                                    StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#6366F1"
                                                                  Offset="0"/>
                                                    <GradientStop Color="#4F46E5"
                                                                  Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#6366F1"
                                                                  Opacity="0.3"
                                                                  BlurRadius="8"
                                                                  ShadowDepth="2"
                                                                  Direction="270"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="💾" FontSize="14"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="حفظ التعديلات"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd"
                                                        Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>