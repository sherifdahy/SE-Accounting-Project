<UserControl x:Class="SA.Accounting.WPF.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             xmlns:enums="clr-namespace:SA.Accounting.Core.Enums;assembly=SA.Accounting.Core"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Loaded="UserControl_Loaded"
             FlowDirection="RightToLeft"
             Background="{StaticResource SurfaceHoverBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <StackPanel Margin="24,20,24,32">

            <!-- ═══════════════════════════════════
                 STATS
            ═══════════════════════════════════ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Transactions -->
                <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="إجمالي المعاملات" Style="{StaticResource StatCaption}"/>
                            <Border Style="{StaticResource StatIconBox}"
                                    Background="{StaticResource InfoLightBrush}">
                                <TextBlock Text="📑" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding TotalCount}" Style="{StaticResource StatValue}"/>
                        <TextBlock Text="معاملة مسجلة"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Foreground="{StaticResource SuccessBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Current Page -->
                <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="الصفحة الحالية" Style="{StaticResource StatCaption}"/>
                            <Border Style="{StaticResource StatIconBox}"
                                    Background="{StaticResource SuccessLightBrush}">
                                <TextBlock Text="📄" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Style="{StaticResource StatValue}">
                            <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                            <Run Text="/" Foreground="{StaticResource TextMutedBrush}"/>
                            <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="من إجمالي الصفحات"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Foreground="{StaticResource InfoBrush}"/>
                    </StackPanel>
                </Border>

                <!-- In This Page -->
                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="في هذه الصفحة" Style="{StaticResource StatCaption}"/>
                            <Border Style="{StaticResource StatIconBox}"
                                    Background="{StaticResource WarningLightBrush}">
                                <TextBlock Text="📋" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Transactions.Count}" Style="{StaticResource StatValue}"/>
                        <TextBlock FontSize="{StaticResource FontSizeSm}"
                                   Foreground="{StaticResource AccentBrush}">
                            <Run Text="من أصل"/>
                            <Run Text="10"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════
                 MAIN CONTENT
            ═══════════════════════════════════ -->
            <Border Style="{StaticResource ContentCard}">
                <StackPanel>

                    <!-- ── Header ── -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="جميع المعاملات" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="إدارة ومتابعة المعاملات المالية"
                                       Style="{StaticResource PageSubtitle}"/>
                        </StackPanel>

                        <telerik:RadButton Grid.Column="1"
                                           Content="+ إضافة معاملة"
                                           Command="{Binding AddTransactionCommand}"
                                           Style="{StaticResource RadBtnPrimary}"
                                           Width="150" Height="36"
                                           FontSize="{StaticResource FontSizeLg}"/>
                    </Grid>

                    <!-- ── Search ── -->
                    <telerik:RadWatermarkTextBox
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        WatermarkContent="🔍 ابحث برقم المعاملة أو الملاحظات..."
                        Style="{StaticResource InputDefault}"
                        Height="38"
                        FontSize="{StaticResource FontSizeLg}"
                        Width="350"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,20"/>

                    <!-- ── Table ── -->
                    <Border Style="{StaticResource TableBorder}">
                        <StackPanel>

                            <!-- Table Header -->
                            <Border Style="{StaticResource TableHeaderBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="130"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="#"
                                               Style="{StaticResource TableHeaderText}"/>
                                    <TextBlock Grid.Column="1" Text="رقم المعاملة"
                                               Style="{StaticResource TableHeaderText}"/>
                                    <TextBlock Grid.Column="2" Text="التاريخ"
                                               Style="{StaticResource TableHeaderText}"/>
                                    <TextBlock Grid.Column="3" Text="الملاحظات"
                                               Style="{StaticResource TableHeaderText}"/>
                                    <TextBlock Grid.Column="4" Text="الحالة"
                                               Style="{StaticResource TableHeaderText}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="إجراءات"
                                               Style="{StaticResource TableHeaderText}"
                                               HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Table Rows -->
                            <ItemsControl ItemsSource="{Binding Transactions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TableRowBorder}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="130"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- ID -->
                                                <TextBlock Grid.Column="0"
                                                           FontSize="{StaticResource FontSizeMd}"
                                                           Foreground="{StaticResource TextPlaceholderBrush}"
                                                           VerticalAlignment="Center">
                                                    <Run Text="#"/><Run Text="{Binding Id, Mode=OneWay}"/>
                                                </TextBlock>

                                                <!-- Number + CreatedAt -->
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <Border Width="40" Height="40"
                                                            CornerRadius="20"
                                                            Margin="0,0,12,0"
                                                            BorderBrush="{StaticResource BorderDefaultBrush}"
                                                            BorderThickness="1"
                                                            ClipToBounds="True">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#EEF2FF" Offset="0"/>
                                                                <GradientStop Color="#E0E7FF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <TextBlock Text="📑" FontSize="18"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Opacity="0.7"/>
                                                    </Border>

                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Number}"
                                                                   FontSize="{StaticResource FontSizeXl}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="160"
                                                                   ToolTip="{Binding Number}"/>
                                                        <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy/MM/dd hh:mm tt}'}"
                                                                   FontSize="{StaticResource FontSizeSm}"
                                                                   Foreground="{StaticResource TextPlaceholderBrush}"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- DateTime -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding DateTime, StringFormat='{}{0:yyyy/MM/dd}'}"
                                                           FontSize="{StaticResource FontSizeMd}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           FlowDirection="LeftToRight"/>

                                                <!-- Note -->
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Note}"
                                                           FontSize="{StaticResource FontSizeMd}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="180"
                                                           ToolTip="{Binding Note}"/>

                                                <!-- Status Badge -->
                                                <Border Grid.Column="4"
                                                        CornerRadius="20" Padding="10,4"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <!-- Default: Initial (جديد) = Warning -->
                                                            <Setter Property="Background"
                                                                    Value="{StaticResource WarningLightBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CurrentState}"
                                                                             Value="{x:Static enums:TransactionState.Approved}">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource SuccessLightBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding CurrentState}"
                                                                             Value="{x:Static enums:TransactionState.Rejected}">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource ErrorLightBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="{StaticResource FontSizeSm}"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <!-- Default: Initial (جديد) -->
                                                                <Setter Property="Text" Value="جديد"/>
                                                                <Setter Property="Foreground"
                                                                        Value="{StaticResource WarningBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CurrentState}"
                                                                                 Value="{x:Static enums:TransactionState.Approved}">
                                                                        <Setter Property="Text" Value="مقبول"/>
                                                                        <Setter Property="Foreground"
                                                                                Value="{StaticResource SuccessBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding CurrentState}"
                                                                                 Value="{x:Static enums:TransactionState.Rejected}">
                                                                        <Setter Property="Text" Value="مرفوض"/>
                                                                        <Setter Property="Foreground"
                                                                                Value="{StaticResource ErrorBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <!-- Actions -->
                                                <StackPanel Grid.Column="5"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">

                                                    <Button ToolTip="عرض"
                                                            Style="{StaticResource BtnTableAction}"
                                                            Command="{Binding DataContext.DisplayTransactionCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="👁️" FontSize="13"/>
                                                    </Button>

                                                    <Button ToolTip="تعديل"
                                                            Style="{StaticResource BtnTableAction}"
                                                            Command="{Binding DataContext.UpdateTransactionCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="✏️" FontSize="13"/>
                                                    </Button>

                                                    <Button ToolTip="حذف"
                                                            Style="{StaticResource BtnTableDanger}"
                                                            Command="{Binding DataContext.DeleteTransactionCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="🗑️" FontSize="13"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty State -->
                            <Border Padding="0,50"
                                    Visibility="{Binding HasNoTransactions,
                                        Converter={StaticResource BoolToVis}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Background="{StaticResource SurfaceAltBrush}"
                                            Width="72" Height="72" CornerRadius="20"
                                            HorizontalAlignment="Center" Margin="0,0,0,16">
                                        <TextBlock Text="📑" FontSize="32"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Opacity="0.6"/>
                                    </Border>
                                    <TextBlock Text="لا يوجد معاملات"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="اضغط على + إضافة معاملة للبدء"
                                               FontSize="{StaticResource FontSizeMd}"
                                               Foreground="{StaticResource TextPlaceholderBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Border>

                    <!-- ═══ Pagination ═══ -->
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding PaginationText}"
                                   FontSize="{StaticResource FontSizeMd}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">

                            <Button Style="{StaticResource PagerNavButton}"
                                    Command="{Binding PreviousPageCommand}"
                                    Content="→" ToolTip="السابق"/>

                            <TextBlock VerticalAlignment="Center"
                                       Margin="12,0"
                                       FontSize="{StaticResource FontSizeMd}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}">
                                <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                                <Run Text="/" Foreground="{StaticResource TextMutedBrush}"/>
                                <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                            </TextBlock>

                            <Button Style="{StaticResource PagerNavButton}"
                                    Command="{Binding NextPageCommand}"
                                    Content="←" ToolTip="التالي"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>