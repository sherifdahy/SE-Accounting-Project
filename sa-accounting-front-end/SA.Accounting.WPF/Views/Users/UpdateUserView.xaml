<UserControl x:Class="SA.Accounting.WPF.Views.UpdateUserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="860"
             FlowDirection="RightToLeft"
             Background="{StaticResource SurfaceHoverBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Tabs -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════
             ROW 0 — Page Header
        ══════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                Padding="24,20,24,16"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Back -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Icon -->
                    <ColumnDefinition Width="*"/>
                    <!-- Title -->
                </Grid.ColumnDefinitions>

                <!-- Back Button -->
                <Button Grid.Column="0"
                        Style="{StaticResource BtnGhost}"
                        Command="{Binding GoBackCommand}"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        ToolTip="رجوع">
                    <TextBlock Text="→" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </Button>

                <!-- Icon -->
                <Border Grid.Column="1"
                        Width="42" Height="42"
                        Background="{StaticResource SurfaceHoverBrush}"
                        CornerRadius="{StaticResource RadiusXl}"
                        Margin="0,0,12,0">
                    <TextBlock Text="✏️" FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Title -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="تعديل بيانات المستخدم"
                               Style="{StaticResource PageHeaderTitle}"/>
                    <TextBlock Text="تعديل البيانات الأساسية والصلاحيات والعُهد"
                               Style="{StaticResource PageHeaderSubtitle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 1 — Tab Bar
        ══════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                Padding="24,0"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">

                <!-- Tab: البيانات الأساسية -->
                <Button Command="{Binding ShowBasicInfoCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentSection}" Value="BasicInfo">
                                    <Setter Property="Foreground"
                                            Value="{StaticResource PrimaryBrush}"/>
                                    <Setter Property="Template"
                                            Value="{StaticResource TabButtonActiveTemplate}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" FontSize="12"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="البيانات الأساسية"
                                   FontSize="{StaticResource FontSizeMd}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <!-- Tab: الشركات -->
                <Button Command="{Binding ShowCompaniesCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentSection}" Value="Companies">
                                    <Setter Property="Foreground"
                                            Value="{StaticResource PrimaryBrush}"/>
                                    <Setter Property="Template"
                                            Value="{StaticResource TabButtonActiveTemplate}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏢" FontSize="12"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="الشركات"
                                   FontSize="{StaticResource FontSizeMd}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <!-- Tab: العُهد -->
                <Button Command="{Binding ShowCustodiesCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentSection}" Value="Custodies">
                                    <Setter Property="Foreground"
                                            Value="{StaticResource PrimaryBrush}"/>
                                    <Setter Property="Template"
                                            Value="{StaticResource TabButtonActiveTemplate}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💰" FontSize="12"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="العُهد"
                                   FontSize="{StaticResource FontSizeMd}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 2 — Tab Content
        ══════════════════════════════════════ -->
        <ContentControl Grid.Row="2"
                        Content="{Binding CurrentViewModel}"
                        Style="{StaticResource TabContentHost}"
                        Margin="0"/>

    </Grid>
</UserControl>