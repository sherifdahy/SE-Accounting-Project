<UserControl x:Class="SA.Accounting.WPF.Views.UserBasicInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             mc:Ignorable="d"
             d:DesignHeight="420"
             d:DesignWidth="540"
             Background="Transparent"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>

        <!-- ═══ Busy Overlay ═══ -->
        <Border Background="#90FFFFFF"
                CornerRadius="{StaticResource RadiusLg}"
                Panel.ZIndex="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <telerik:RadBusyIndicator
                    IsBusy="True" BusyContent=""
                    IsIndeterminate="True"
                    Width="40" Height="40"/>
                <TextBlock FontSize="{StaticResource FontSizeSm}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="جارٍ الحفظ..."/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Text" Value="جارٍ تحميل البيانات..."/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ═══ Main Content ═══ -->
        <ScrollViewer Panel.ZIndex="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,24">

                <!-- ══════ Section: المعلومات الشخصية ══════ -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Style="{StaticResource SectionIndicator}"
                                    Background="{StaticResource TextPrimaryBrush}"/>
                            <StackPanel>
                                <TextBlock Text="المعلومات الشخصية"
                                           Style="{StaticResource SectionLabel}"/>
                                <TextBlock Text="الاسم وبيانات التواصل"
                                           Style="{StaticResource SectionSubtext}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Row 1: الاسم + الرقم القومي -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="الاسم الكامل"
                                               Style="{StaticResource InputLabel}" Margin="0"/>
                                    <TextBlock Style="{StaticResource RequiredStar}"/>
                                </StackPanel>
                                <telerik:RadWatermarkTextBox
                                    x:Name="NameBox"
                                    WatermarkContent="أدخل الاسم الكامل"
                                    Text="{Binding Name, Mode=TwoWay,
                                           UpdateSourceTrigger=PropertyChanged,
                                           ValidatesOnNotifyDataErrors=True}"
                                    Style="{StaticResource InputDefault}"
                                    Validation.ErrorTemplate="{x:Null}"/>
                                <TextBlock Style="{StaticResource ValidationError}"
                                           Text="{Binding (Validation.Errors)[0].ErrorContent,
                                                  ElementName=NameBox}"
                                           Visibility="{Binding (Validation.HasError),
                                                        ElementName=NameBox,
                                                        Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="الرقم القومي"
                                               Style="{StaticResource InputLabel}" Margin="0"/>
                                    <TextBlock Style="{StaticResource RequiredStar}"/>
                                </StackPanel>
                                <telerik:RadWatermarkTextBox
                                    x:Name="SsnBox"
                                    WatermarkContent="أدخل الرقم القومي"
                                    Text="{Binding SSN, Mode=TwoWay,
                                           UpdateSourceTrigger=PropertyChanged,
                                           ValidatesOnNotifyDataErrors=True}"
                                    Style="{StaticResource InputDefault}"
                                    FlowDirection="LeftToRight"
                                    HorizontalContentAlignment="Left"
                                    Validation.ErrorTemplate="{x:Null}"/>
                                <TextBlock Style="{StaticResource ValidationError}"
                                           Text="{Binding (Validation.Errors)[0].ErrorContent,
                                                  ElementName=SsnBox}"
                                           Visibility="{Binding (Validation.HasError),
                                                        ElementName=SsnBox,
                                                        Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 2: البريد + رقم الهاتف -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="البريد الإلكتروني"
                                               Style="{StaticResource InputLabel}" Margin="0"/>
                                    <TextBlock Style="{StaticResource RequiredStar}"/>
                                </StackPanel>
                                <telerik:RadWatermarkTextBox
                                    x:Name="EmailBox"
                                    WatermarkContent="example@email.com"
                                    Text="{Binding Email, Mode=TwoWay,
                                           UpdateSourceTrigger=PropertyChanged,
                                           ValidatesOnNotifyDataErrors=True}"
                                    Style="{StaticResource InputDefault}"
                                    FlowDirection="LeftToRight"
                                    HorizontalContentAlignment="Left"
                                    Validation.ErrorTemplate="{x:Null}"/>
                                <TextBlock Style="{StaticResource ValidationError}"
                                           Text="{Binding (Validation.Errors)[0].ErrorContent,
                                                  ElementName=EmailBox}"
                                           Visibility="{Binding (Validation.HasError),
                                                        ElementName=EmailBox,
                                                        Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="رقم الهاتف"
                                               Style="{StaticResource InputLabel}" Margin="0"/>
                                    <TextBlock Style="{StaticResource RequiredStar}"/>
                                </StackPanel>
                                <telerik:RadWatermarkTextBox
                                    x:Name="PhoneBox"
                                    WatermarkContent="05XXXXXXXX"
                                    Text="{Binding PhoneNumber, Mode=TwoWay,
                                           UpdateSourceTrigger=PropertyChanged,
                                           ValidatesOnNotifyDataErrors=True}"
                                    Style="{StaticResource InputDefault}"
                                    FlowDirection="LeftToRight"
                                    HorizontalContentAlignment="Left"
                                    Validation.ErrorTemplate="{x:Null}"/>
                                <TextBlock Style="{StaticResource ValidationError}"
                                           Text="{Binding (Validation.Errors)[0].ErrorContent,
                                                  ElementName=PhoneBox}"
                                           Visibility="{Binding (Validation.HasError),
                                                        ElementName=PhoneBox,
                                                        Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ══════ Section: بيانات الأمان ══════ -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Style="{StaticResource SectionIndicator}"
                                    Background="{StaticResource InfoBrush}"/>
                            <StackPanel>
                                <TextBlock Text="بيانات الأمان"
                                           Style="{StaticResource SectionLabel}"/>
                                <TextBlock Text="الصلاحية وكلمة المرور"
                                           Style="{StaticResource SectionSubtext}"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- الصلاحية -->
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="الصلاحية"
                                               Style="{StaticResource InputLabel}" Margin="0"/>
                                    <TextBlock Style="{StaticResource RequiredStar}"/>
                                </StackPanel>
                                <Grid>
                                    <telerik:RadComboBox
                                        ItemsSource="{Binding Roles}"
                                        SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                        DisplayMemberPath="Name"
                                        EmptyText="اختر الصلاحية"
                                        Style="{StaticResource ModernComboBoxStyle}">
                                    </telerik:RadComboBox>

                                    <!-- Loading indicator -->
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="جارٍ التحميل..."
                                                   FontSize="{StaticResource FontSizeXs}"
                                                   Foreground="{StaticResource TextPlaceholderBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- كلمة المرور -->
                            <StackPanel Grid.Column="2">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="كلمة المرور الجديدة"
                                               Style="{StaticResource InputLabel}" Margin="0"/>
                                </StackPanel>
                                <telerik:RadPasswordBox
                                    x:Name="PasswordBox"
                                    WatermarkContent="اتركها فارغة إن لم تُغيّر"
                                    PasswordChanged="RadPasswordBox_PasswordChanged"
                                    Height="{StaticResource InputHeightLg}"
                                    Padding="{StaticResource InputPadding}"
                                    FontSize="{StaticResource FontSizeMd}"
                                    BorderBrush="{StaticResource BorderDefaultBrush}"
                                    BorderThickness="1"
                                    Background="{StaticResource InputBackgroundBrush}"
                                    FlowDirection="LeftToRight"
                                    HorizontalContentAlignment="Left"
                                    VerticalContentAlignment="Center"/>
                                <TextBlock Text="اتركها فارغة إذا لم ترغب في التغيير"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextPlaceholderBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ══════ Save Button ══════ -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="0,4,0,0">

                    <telerik:RadButton Style="{StaticResource RadBtnPrimary}"
                                       MinWidth="160" Height="34"
                                       Command="{Binding UpdateCurrentUserCommand}">
                        <telerik:RadButton.Content>
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="✓" FontSize="13" Foreground="White"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="حفظ البيانات الأساسية"
                                               FontSize="{StaticResource FontSizeMd}"
                                               FontWeight="SemiBold" Foreground="White"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Text="جارٍ الحفظ..."
                                           FontSize="{StaticResource FontSizeMd}"
                                           FontWeight="SemiBold"
                                           Foreground="White">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </telerik:RadButton.Content>
                    </telerik:RadButton>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>