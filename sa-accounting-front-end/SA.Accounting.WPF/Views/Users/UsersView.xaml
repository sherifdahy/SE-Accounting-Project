<UserControl x:Class="SA.Accounting.WPF.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Loaded="UserControl_Loaded"
             FlowDirection="RightToLeft"
             Background="{StaticResource SurfaceHoverBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <StackPanel Margin="24,20,24,32">

            <!-- ═══ Stats ═══ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="إجمالي المستخدمين" Style="{StaticResource StatCaption}"/>
                            <Border Style="{StaticResource StatIconBox}"
                                    Background="{StaticResource InfoLightBrush}">
                                <TextBlock Text="👥" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding TotalCount}" Style="{StaticResource StatValue}"/>
                        <TextBlock Text="مستخدم مسجل"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Foreground="{StaticResource SuccessBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="الصفحة الحالية" Style="{StaticResource StatCaption}"/>
                            <Border Style="{StaticResource StatIconBox}"
                                    Background="{StaticResource SuccessLightBrush}">
                                <TextBlock Text="📄" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Style="{StaticResource StatValue}">
                            <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                            <Run Text="/" Foreground="{StaticResource TextMutedBrush}"/>
                            <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="من إجمالي الصفحات"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Foreground="{StaticResource InfoBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="في هذه الصفحة" Style="{StaticResource StatCaption}"/>
                            <Border Style="{StaticResource StatIconBox}"
                                    Background="{StaticResource WarningLightBrush}">
                                <TextBlock Text="📋" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Users.Count}" Style="{StaticResource StatValue}"/>
                        <TextBlock FontSize="{StaticResource FontSizeSm}"
                                   Foreground="{StaticResource AccentBrush}">
                            <Run Text="من أصل"/>
                            <Run Text="10"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ Main Content ═══ -->
            <Border Style="{StaticResource ContentCard}">
                <StackPanel>

                    <!-- Header -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="جميع المستخدمين" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="إدارة ومتابعة معلومات المستخدمين"
                                       Style="{StaticResource PageSubtitle}"/>
                        </StackPanel>

                        <telerik:RadButton Grid.Column="1"
                                           Content="+ إضافة مستخدم"
                                           Command="{Binding AddUserCommand}"
                                           Style="{StaticResource RadBtnPrimary}"
                                           Width="140" Height="36"
                                           FontSize="{StaticResource FontSizeLg}"/>
                    </Grid>

                    <!-- Search -->
                    <telerik:RadWatermarkTextBox
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        WatermarkContent="🔍 ابحث بالاسم أو البريد أو رقم الهاتف..."
                        Style="{StaticResource InputDefault}"
                        Height="38"
                        FontSize="{StaticResource FontSizeLg}"
                        Width="400"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,20"/>

                    <!-- Table -->
                    <Border Style="{StaticResource TableBorder}">
                        <StackPanel>

                            <!-- Header -->
                            <Border Style="{StaticResource TableHeaderBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="0.8*"/>
                                        <ColumnDefinition Width="0.8*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="#"
                                               Style="{StaticResource TableHeaderText}"/>
                                    <TextBlock Grid.Column="1" Text="المستخدم"
                                               Style="{StaticResource TableHeaderText}"/>
                                    <TextBlock Grid.Column="2" Text="البريد الإلكتروني"
                                               Style="{StaticResource TableHeaderText}"/>
                                    <TextBlock Grid.Column="3" Text="رقم الهاتف"
                                               Style="{StaticResource TableHeaderText}"/>
                                    <TextBlock Grid.Column="4" Text="الدور"
                                               Style="{StaticResource TableHeaderText}"/>
                                    <TextBlock Grid.Column="5" Text="الحالة"
                                               Style="{StaticResource TableHeaderText}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="6" Text="إجراءات"
                                               Style="{StaticResource TableHeaderText}"
                                               HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Rows -->
                            <ItemsControl ItemsSource="{Binding Users}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TableRowBorder}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="0.8*"/>
                                                    <ColumnDefinition Width="0.8*"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="110"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- ID -->
                                                <TextBlock Grid.Column="0"
                                                           FontSize="{StaticResource FontSizeMd}"
                                                           Foreground="{StaticResource TextPlaceholderBrush}"
                                                           VerticalAlignment="Center">
                                                    <Run Text="#"/><Run Text="{Binding Id, Mode=OneWay}"/>
                                                </TextBlock>

                                                <!-- Name + SSN -->
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <Border Width="40" Height="40"
                                                            CornerRadius="20"
                                                            Margin="0,0,12,0"
                                                            BorderBrush="{StaticResource BorderDefaultBrush}"
                                                            BorderThickness="1"
                                                            ClipToBounds="True">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#EEF2FF" Offset="0"/>
                                                                <GradientStop Color="#E0E7FF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <TextBlock Text="👤" FontSize="18"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Opacity="0.7"/>
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="{StaticResource FontSizeXl}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="160"
                                                                   ToolTip="{Binding Name}"/>
                                                        <TextBlock Text="{Binding SSN}"
                                                                   FontSize="{StaticResource FontSizeSm}"
                                                                   Foreground="{StaticResource TextPlaceholderBrush}"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Email -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Email}"
                                                           FontSize="{StaticResource FontSizeMd}"
                                                           Foreground="{StaticResource InfoBrush}"
                                                           VerticalAlignment="Center"
                                                           FlowDirection="LeftToRight"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Email}"
                                                           Opacity="0.85"/>

                                                <!-- Phone -->
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding PhoneNumber}"
                                                           FontSize="{StaticResource FontSizeMd}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           FlowDirection="LeftToRight"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding PhoneNumber}"/>

                                                <!-- Role -->
                                                <Border Grid.Column="4"
                                                        CornerRadius="{StaticResource RadiusMd}"
                                                        Padding="8,4"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background"
                                                                    Value="{StaticResource SurfaceHoverBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Role}" Value="Admin">
                                                                    <Setter Property="Background" Value="#F3E8FF"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Role}"
                                                               FontSize="{StaticResource FontSizeSm}"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground"
                                                                        Value="{StaticResource TextMutedBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Role}" Value="Admin">
                                                                        <Setter Property="Foreground" Value="#7C3AED"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <!-- Status -->
                                                <Border Grid.Column="5"
                                                        CornerRadius="20" Padding="10,4"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background"
                                                                    Value="{StaticResource SuccessLightBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource ErrorLightBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="{StaticResource FontSizeSm}"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="نشط"/>
                                                                <Setter Property="Foreground"
                                                                        Value="{StaticResource SuccessBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                                        <Setter Property="Text" Value="محذوف"/>
                                                                        <Setter Property="Foreground"
                                                                                Value="{StaticResource ErrorBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <!-- Actions -->
                                                <StackPanel Grid.Column="6"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">

                                                    <Button ToolTip="تعديل"
                                                            Style="{StaticResource BtnTableAction}"
                                                            Command="{Binding DataContext.UpdateUserCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="✏️" FontSize="13"/>
                                                    </Button>

                                                    <Button ToolTip="حذف"
                                                            Style="{StaticResource BtnTableDanger}"
                                                            Command="{Binding DataContext.DeleteUserCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="🗑️" FontSize="13"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty State -->
                            <Border Padding="0,50"
                                    Visibility="{Binding HasNoUsers, Converter={StaticResource BoolToVis}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Background="{StaticResource SurfaceAltBrush}"
                                            Width="72" Height="72" CornerRadius="20"
                                            HorizontalAlignment="Center" Margin="0,0,0,16">
                                        <TextBlock Text="👥" FontSize="32"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Opacity="0.6"/>
                                    </Border>
                                    <TextBlock Text="لا يوجد مستخدمين"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="اضغط على + إضافة مستخدم للبدء"
                                               FontSize="{StaticResource FontSizeMd}"
                                               Foreground="{StaticResource TextPlaceholderBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Border>

                    <!-- ═══ Pagination ═══ -->
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding PaginationText}"
                                   FontSize="{StaticResource FontSizeMd}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource PagerNavButton}"
                                    Command="{Binding PreviousPageCommand}"
                                    Content="→" ToolTip="السابق"/>

                            <TextBlock VerticalAlignment="Center" Margin="12,0"
                                       FontSize="{StaticResource FontSizeMd}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}">
                                <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                                <Run Text="/" Foreground="{StaticResource TextMutedBrush}"/>
                                <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                            </TextBlock>

                            <Button Style="{StaticResource PagerNavButton}"
                                    Command="{Binding NextPageCommand}"
                                    Content="←" ToolTip="التالي"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>