<UserControl
    x:Class="SA.Accounting.WPF.Views.CreateUserView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    mc:Ignorable="d"
    FlowDirection="RightToLeft"
    d:DesignHeight="580"
    d:DesignWidth="540"
    Loaded="UserControl_Loaded"
    Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border Background="{StaticResource SurfaceBrush}"
            CornerRadius="{StaticResource Radius2Xl}">
        <Grid>

            <!-- ═══ طبقة التعتيم أثناء الحفظ ═══ -->
            <Border Background="#90FFFFFF"
                    CornerRadius="{StaticResource Radius2Xl}"
                    Panel.ZIndex="10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <telerik:RadBusyIndicator
                        IsBusy="True" BusyContent=""
                        IsIndeterminate="True"
                        Width="45" Height="45"/>
                    <TextBlock Text="جارٍ الحفظ..."
                               FontSize="{StaticResource FontSizeMd}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- ═══ المحتوى ═══ -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Panel.ZIndex="1">
                <StackPanel Margin="24,20,24,20">

                    <!-- ═══ Header ═══ -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="42" Height="42"
                                Background="{StaticResource SurfaceHoverBrush}"
                                CornerRadius="{StaticResource RadiusXl}"
                                Margin="0,0,12,0">
                            <TextBlock Text="👤" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="إضافة مستخدم جديد"
                                       Style="{StaticResource PageHeaderTitle}"/>
                            <TextBlock Text="تعبئة البيانات لإنشاء حساب مستخدم جديد"
                                       Style="{StaticResource PageHeaderSubtitle}"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource BtnGhost}"
                                ToolTip="إغلاق"
                                VerticalAlignment="Top">
                            <TextBlock Text="✕" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderDefaultBrush}"
                            Margin="0,0,0,16"/>

                    <!-- ═══ المعلومات الأساسية ═══ -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Style="{StaticResource SectionIndicator}"
                                Background="{StaticResource TextPrimaryBrush}"/>
                        <StackPanel>
                            <TextBlock Text="المعلومات الأساسية"
                                       Style="{StaticResource SectionLabel}"/>
                            <TextBlock Text="بيانات المستخدم الشخصية"
                                       Style="{StaticResource SectionSubtext}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- صف 1: الاسم + البريد -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="اسم المستخدم"
                                           Style="{StaticResource InputLabel}" Margin="0"/>
                                <TextBlock Style="{StaticResource RequiredStar}"/>
                            </StackPanel>
                            <telerik:RadWatermarkTextBox
                                x:Name="NameBox"
                                Text="{Binding Name, Mode=TwoWay,
                                       UpdateSourceTrigger=PropertyChanged,
                                       ValidatesOnNotifyDataErrors=True}"
                                WatermarkContent="أدخل الاسم..."
                                Style="{StaticResource InputDefault}"
                                Validation.ErrorTemplate="{x:Null}"/>
                            <TextBlock Style="{StaticResource ValidationError}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                              ElementName=NameBox}"
                                       Visibility="{Binding (Validation.HasError),
                                                    ElementName=NameBox,
                                                    Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="البريد الإلكتروني"
                                           Style="{StaticResource InputLabel}" Margin="0"/>
                                <TextBlock Style="{StaticResource RequiredStar}"/>
                            </StackPanel>
                            <telerik:RadWatermarkTextBox
                                x:Name="EmailBox"
                                Text="{Binding Email, Mode=TwoWay,
                                       UpdateSourceTrigger=PropertyChanged,
                                       ValidatesOnNotifyDataErrors=True}"
                                WatermarkContent="example@mail.com"
                                Style="{StaticResource InputDefault}"
                                FlowDirection="LeftToRight"
                                HorizontalContentAlignment="Left"
                                Validation.ErrorTemplate="{x:Null}"/>
                            <TextBlock Style="{StaticResource ValidationError}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                              ElementName=EmailBox}"
                                       Visibility="{Binding (Validation.HasError),
                                                    ElementName=EmailBox,
                                                    Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- صف 2: الرقم القومي + رقم الهاتف -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="الرقم القومي"
                                           Style="{StaticResource InputLabel}" Margin="0"/>
                                <TextBlock Style="{StaticResource RequiredStar}"/>
                            </StackPanel>
                            <telerik:RadWatermarkTextBox
                                x:Name="SsnBox"
                                Text="{Binding Ssn, Mode=TwoWay,
                                       UpdateSourceTrigger=PropertyChanged,
                                       ValidatesOnNotifyDataErrors=True}"
                                WatermarkContent="أدخل الرقم القومي..."
                                Style="{StaticResource InputDefault}"
                                FlowDirection="LeftToRight"
                                HorizontalContentAlignment="Left"
                                Validation.ErrorTemplate="{x:Null}"/>
                            <TextBlock Style="{StaticResource ValidationError}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                              ElementName=SsnBox}"
                                       Visibility="{Binding (Validation.HasError),
                                                    ElementName=SsnBox,
                                                    Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="رقم الهاتف"
                                           Style="{StaticResource InputLabel}" Margin="0"/>
                                <TextBlock Style="{StaticResource RequiredStar}"/>
                            </StackPanel>
                            <telerik:RadWatermarkTextBox
                                x:Name="PhoneBox"
                                Text="{Binding PhoneNumber, Mode=TwoWay,
                                       UpdateSourceTrigger=PropertyChanged,
                                       ValidatesOnNotifyDataErrors=True}"
                                WatermarkContent="05XXXXXXXX"
                                Style="{StaticResource InputDefault}"
                                FlowDirection="LeftToRight"
                                HorizontalContentAlignment="Left"
                                Validation.ErrorTemplate="{x:Null}"/>
                            <TextBlock Style="{StaticResource ValidationError}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                              ElementName=PhoneBox}"
                                       Visibility="{Binding (Validation.HasError),
                                                    ElementName=PhoneBox,
                                                    Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderDefaultBrush}"
                            Margin="0,6,0,16"/>

                    <!-- ═══ بيانات الأمان ═══ -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Style="{StaticResource SectionIndicator}"
                                Background="{StaticResource InfoBrush}"/>
                        <StackPanel>
                            <TextBlock Text="بيانات الأمان"
                                       Style="{StaticResource SectionLabel}"/>
                            <TextBlock Text="كلمة المرور والصلاحيات"
                                       Style="{StaticResource SectionSubtext}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- صف 3: كلمة المرور + الدور -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="كلمة المرور"
                                           Style="{StaticResource InputLabel}" Margin="0"/>
                                <TextBlock Style="{StaticResource RequiredStar}"/>
                            </StackPanel>
                            <telerik:RadWatermarkTextBox
                                x:Name="PasswordBox"
                                Text="{Binding Password, Mode=TwoWay,
                                       UpdateSourceTrigger=PropertyChanged,
                                       ValidatesOnNotifyDataErrors=True}"
                                WatermarkContent="أدخل كلمة المرور..."
                                Style="{StaticResource InputDefault}"
                                FlowDirection="LeftToRight"
                                HorizontalContentAlignment="Left"
                                Validation.ErrorTemplate="{x:Null}"/>
                            <TextBlock Style="{StaticResource ValidationError}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                              ElementName=PasswordBox}"
                                       Visibility="{Binding (Validation.HasError),
                                                    ElementName=PasswordBox,
                                                    Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="الدور"
                                           Style="{StaticResource InputLabel}" Margin="0"/>
                                <TextBlock Style="{StaticResource RequiredStar}"/>
                            </StackPanel>
                            <Grid>
                                <telerik:RadComboBox
                                    ItemsSource="{Binding Roles}"
                                    DisplayMemberPath="Name"
                                    SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                    EmptyText="اختر الدور..."
                                    Style="{StaticResource ModernComboBoxStyle}">
                                </telerik:RadComboBox>

                                <!-- مؤشر تحميل صغير -->
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLoadingRoles}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="جارٍ التحميل..."
                                               FontSize="{StaticResource FontSizeXs}"
                                               Foreground="{StaticResource TextPlaceholderBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderDefaultBrush}"
                            Margin="0,6,0,18"/>

                    <!-- ═══ Buttons ═══ -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left">

                        <Button Style="{StaticResource BtnOutline}"
                                Width="100" Margin="0,0,10,0"
                                Command="{Binding CancelCommand}">
                            <TextBlock Text="إلغاء"
                                       FontSize="{StaticResource FontSizeMd}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>

                        <telerik:RadButton Style="{StaticResource RadBtnPrimary}"
                                           MinWidth="130" Height="34"
                                           Command="{Binding SaveCommand}">
                            <telerik:RadButton.Content>
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="✓" FontSize="13" Foreground="White"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="حفظ المستخدم"
                                                   FontSize="{StaticResource FontSizeMd}"
                                                   FontWeight="SemiBold" Foreground="White"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Text="جارٍ الحفظ..."
                                               FontSize="{StaticResource FontSizeMd}"
                                               FontWeight="SemiBold"
                                               Foreground="White">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </telerik:RadButton.Content>
                        </telerik:RadButton>

                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>