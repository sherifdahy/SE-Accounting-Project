<Window
    x:Class="SA.Accounting.WPF.Windows.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    Title="تسجيل الدخول - SA Accounting"
    Height="650" 
    Width="480"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    FlowDirection="RightToLeft"
    Background="#F9FAFB">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. HEADER -->
            <StackPanel Grid.Row="0" Margin="0,0,0,40" HorizontalAlignment="Center">

                <Border Width="80" Height="80" 
                        CornerRadius="20" 
                        Background="#000000" 
                        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" 
                                          Opacity="0.15" 
                                          BlurRadius="20" 
                                          ShadowDepth="4"/>
                    </Border.Effect>
                    <TextBlock Text="SA" 
                               Foreground="White" 
                               FontWeight="Bold" 
                               FontSize="32" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="مرحباً بعودتك!"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#111827"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <TextBlock Text="يرجى تسجيل الدخول للمتابعة"
                           FontSize="14"
                           Foreground="#6B7280"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 2. FORM -->
            <StackPanel Grid.Row="1" Margin="0,0,0,30">

                <!-- Email -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="البريد الإلكتروني" 
                               Style="{StaticResource InputLabelStyle}"/>
                    <telerik:RadWatermarkTextBox
                        x:Name="EmailTxt"
                        WatermarkContent="example@domain.com"
                        Style="{StaticResource ModernInputStyle}"
                        Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, 
                               ValidatesOnNotifyDataErrors=True}"
                        Validation.ErrorTemplate="{x:Null}"
                        KeyUp="Input_KeyUp"/>
                    <TextBlock Style="{StaticResource ValidationTextBlock}"
                               Text="{Binding (Validation.Errors)[0].ErrorContent,
                                      ElementName=EmailTxt}"
                               Visibility="{Binding (Validation.HasError),
                                            ElementName=EmailTxt,
                                            Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <!-- Password -->
                <StackPanel Margin="0,0,0,16">
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="كلمة المرور" 
                                   Style="{StaticResource InputLabelStyle}"
                                   Margin="0"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="هل نسيت كلمة المرور؟"
                                   Style="{StaticResource HyperlinkStyle}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <telerik:RadPasswordBox
                        x:Name="PasswordTxt"
                        WatermarkContent="••••••••"
                        Style="{StaticResource RowInputStyle}"
                        PasswordChanged="PasswordTxt_PasswordChanged"
                        KeyUp="Input_KeyUp"/>
                    <TextBlock Style="{StaticResource ValidationTextBlock}"
                               Text="{Binding (Validation.Errors)[0].ErrorContent,
                                      ElementName=PasswordTxt}"
                               Visibility="{Binding (Validation.HasError),
                                            ElementName=PasswordTxt,
                                            Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <!-- Remember Me -->
                <CheckBox Content="تذكرني" 
                          Foreground="#6B7280"
                          FontSize="13"
                          Margin="0,0,0,24"
                          VerticalContentAlignment="Center">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="CheckBox">
                                        <StackPanel Orientation="Horizontal">
                                            <Border x:Name="Border"
                                                    Width="18" 
                                                    Height="18"
                                                    CornerRadius="4"
                                                    BorderBrush="#D1D5DB"
                                                    BorderThickness="1.5"
                                                    Background="White"
                                                    Margin="0,0,8,0">
                                                <Path x:Name="CheckMark"
                                                      Data="M 2 6 L 6 10 L 14 2"
                                                      Stroke="White"
                                                      StrokeThickness="2"
                                                      Visibility="Collapsed"/>
                                            </Border>
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#000000"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#000000"/>
                                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#9CA3AF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>

                <!-- Login Button -->
                <telerik:RadButton
                    x:Name="LoginBtn"
                    Style="{StaticResource ModernButtonStyle}"
                    Content="تسجيل الدخول"
                    Command="{Binding LoginCommand}"/>

            </StackPanel>

            <!-- 3. FOOTER -->
            <StackPanel Grid.Row="2" 
                        HorizontalAlignment="Center" 
                        Orientation="Horizontal"
                        Margin="0,0,0,20">
                <TextBlock Text="ليس لديك حساب؟" 
                           Foreground="#6B7280" 
                           FontSize="13"
                           Margin="0,0,5,0"/>
                <TextBlock Text="إنشاء حساب جديد" 
                           Style="{StaticResource HyperlinkStyle}"/>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</Window>