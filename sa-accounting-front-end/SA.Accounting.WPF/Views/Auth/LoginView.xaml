<UserControl x:Class="SA.Accounting.WPF.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             FlowDirection="RightToLeft"
             Background="#F9FAFB">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="#F9FAFB"
          FocusManager.FocusedElement="{Binding ElementName=EmailTxt}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="1.1*" />
        </Grid.ColumnDefinitions>

        <!-- Right Side / Branding -->
        <Border Grid.Column="0" Background="#111827">
            <Grid Margin="40">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="90"
                            Height="90"
                            CornerRadius="22"
                            Background="White"
                            Margin="0,0,0,30">
                        <TextBlock Text="SE"
                                   Foreground="#111827"
                                   FontWeight="Bold"
                                   FontSize="34"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Saber Eid Accounting"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="نظام محاسبي احترافي لإدارة أعمالك بسهولة وكفاءة"
                               Foreground="#D1D5DB"
                               FontSize="15"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="280"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Left Side / Form -->
        <Grid Grid.Column="1" Background="#F9FAFB">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="60,40">
                    <StackPanel VerticalAlignment="Center" MaxWidth="360">

                        <!-- Header -->
                        <StackPanel Margin="0,0,0,32">
                            <TextBlock Text="مرحباً بعودتك!"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="#111827"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="يرجى تسجيل الدخول للمتابعة إلى حسابك"
                                       FontSize="14"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Email -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="البريد الإلكتروني"
                                       Style="{StaticResource InputLabelStyle}"/>
                            <telerik:RadWatermarkTextBox
                                x:Name="EmailTxt"
                                WatermarkContent="example@domain.com"
                                Style="{StaticResource ModernInputStyle}"
                                Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Style="{StaticResource ValidationTextBlock}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=EmailTxt}"
                                       Visibility="{Binding (Validation.HasError), ElementName=EmailTxt, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <!-- Password -->
                        <StackPanel Margin="0,0,0,16">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="كلمة المرور"
                                           Style="{StaticResource InputLabelStyle}"
                                           HorizontalAlignment="Left"/>
                            </Grid>

                            <telerik:RadPasswordBox
                                    x:Name="PasswordTxt"
                                    WatermarkContent="••••••••"
                                    PasswordChanged="PasswordTxt_PasswordChanged"
                                    Style="{StaticResource RowInputStyle}"/>

                            <TextBlock Style="{StaticResource ValidationTextBlock}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=PasswordTxt}"
                                       Visibility="{Binding (Validation.HasError), ElementName=PasswordTxt, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <!-- Login Button -->
                        <telerik:RadButton
                            x:Name="LoginBtn"
                            Style="{StaticResource ModernButtonStyle}"
                            Content="تسجيل الدخول"
                            Command="{Binding LoginCommand}"
                            Margin="0,0,0,24"/>

                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>