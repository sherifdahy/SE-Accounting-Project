<UserControl x:Class="SA.Accounting.WPF.Views.DisplayCompanyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             Background="{StaticResource SurfaceHoverBrush}"
             d:DesignWidth="860">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,20,24,32">

            <!-- ══════ Page Header ══════ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="46" Height="46"
                            Background="{StaticResource PrimaryBrush}"
                            CornerRadius="{StaticResource Radius2Xl}"
                            Margin="0,0,14,0">
                        <TextBlock Text="🏢" FontSize="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>

                            <!-- Status Badge -->
                            <Border CornerRadius="8" Padding="10,3"
                                    Margin="12,0,0,0" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{StaticResource SuccessLightBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                <Setter Property="Background"
                                                        Value="{StaticResource ErrorLightBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="{StaticResource FontSizeSm}" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="نشطة"/>
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource SuccessBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                    <Setter Property="Text" Value="محذوفة"/>
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource ErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="تفاصيل الشركة والحسابات المرتبطة بها"
                                   Style="{StaticResource PageHeaderSubtitle}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Back Button -->
                <Button Grid.Column="1"
                        Style="{StaticResource BtnGhost}"
                        Command="{Binding BackCommand}"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="→" FontSize="16"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="رجوع للقائمة"
                                   FontSize="{StaticResource FontSizeMd}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontWeight="Medium" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ══════ Info Cards ══════ -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tax Registration -->
                <Border Grid.Column="0" Style="{StaticResource InfoCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Style="{StaticResource InfoIconBox}"
                                    Background="{StaticResource InfoLightBrush}">
                                <TextBlock Text="📋" FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="السجل الضريبي"
                                       FontSize="{StaticResource FontSizeSm}"
                                       Foreground="{StaticResource TextPlaceholderBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TaxRegistrationNumber}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Tax File -->
                <Border Grid.Column="2" Style="{StaticResource InfoCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Style="{StaticResource InfoIconBox}"
                                    Background="{StaticResource WarningLightBrush}">
                                <TextBlock Text="📄" FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="الملف الضريبي"
                                       FontSize="{StaticResource FontSizeSm}"
                                       Foreground="{StaticResource TextPlaceholderBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TaxFileNumber}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Accounts Count -->
                <Border Grid.Column="4" Style="{StaticResource InfoCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Style="{StaticResource InfoIconBox}"
                                    Background="#EDE9FE">
                                <TextBlock Text="🌐" FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="حسابات المنصات"
                                       FontSize="{StaticResource FontSizeSm}"
                                       Foreground="{StaticResource TextPlaceholderBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Accounts.Count}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════ العنوان ══════ -->
            <Border Style="{StaticResource InfoCard}" Margin="0,0,0,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="📍" FontSize="13" Margin="0,0,5,0"/>
                        <TextBlock Text="العنوان"
                                   Style="{StaticResource InfoCaption}" Margin="0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Address}"
                               Style="{StaticResource InfoValue}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ══════ المالكون ══════ -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Style="{StaticResource SectionIndicator}"
                                Background="{StaticResource WarningBrush}"/>
                        <TextBlock Text="المالكون" FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Border Style="{StaticResource BadgeWarning}"
                                Padding="8,2" Margin="8,0,0,0">
                            <TextBlock Text="{Binding Owners.Count}"
                                       FontSize="{StaticResource FontSizeXs}"
                                       FontWeight="SemiBold" Foreground="#92400E"/>
                        </Border>
                    </StackPanel>

                    <!-- Owner Cards -->
                    <ItemsControl ItemsSource="{Binding Owners}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardHighlight}"
                                        Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="38" Height="38"
                                                Background="#FDE68A"
                                                CornerRadius="19"
                                                Margin="0,0,12,0">
                                            <TextBlock Text="👤" FontSize="16"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="{StaticResource FontSizeLg}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="هوية:"
                                                           FontSize="{StaticResource FontSizeSm}"
                                                           Foreground="{StaticResource TextPlaceholderBrush}"
                                                           Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding SSN}"
                                                           FontSize="{StaticResource FontSizeSm}"
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty -->
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCard}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Owners.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="لا يوجد مالكون مسجلون"
                                   FontSize="{StaticResource FontSizeMd}"
                                   Foreground="{StaticResource TextPlaceholderBrush}"
                                   HorizontalAlignment="Center"/>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ══════ حسابات المنصات ══════ -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Style="{StaticResource SectionIndicator}"
                                Background="{StaticResource InfoBrush}"/>
                        <TextBlock Text="حسابات المنصات" FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Border Background="{StaticResource InfoLightBrush}"
                                CornerRadius="8" Padding="8,2"
                                Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Accounts.Count}"
                                       FontSize="{StaticResource FontSizeXs}"
                                       FontWeight="SemiBold" Foreground="#4338CA"/>
                        </Border>
                        <TextBlock Text="   •   اضغط على أي حساب لفتح المنصة"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Foreground="{StaticResource TextPlaceholderBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Account Cards -->
                    <ItemsControl ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardClickable}"
                                        Margin="0,0,8,8">

                                    <!-- Wrap in Button for Command binding -->
                                    <Button Style="{StaticResource BtnGhost}"
                                            Padding="0"
                                            Command="{Binding DataContext.OpenPlatformCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Platform Icon -->
                                            <Border Grid.Column="0" Width="46" Height="46"
                                                    CornerRadius="{StaticResource Radius2Xl}"
                                                    Background="{StaticResource InfoLightBrush}">
                                                <TextBlock Text="🌐" FontSize="22"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Details -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">

                                                <TextBlock Text="{Binding Platform.Name, FallbackValue='منصة'}"
                                                           FontSize="{StaticResource FontSizeLg}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Margin="0,0,0,4"/>

                                                <!-- Email -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                    <TextBlock Text="📧" FontSize="11" Margin="0,0,6,0"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Email}"
                                                               FontSize="{StaticResource FontSizeMd}"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <Button Style="{StaticResource BtnGhost}"
                                                            Padding="5,3" Margin="6,0,0,0"
                                                            ToolTip="نسخ البريد"
                                                            Command="{Binding DataContext.CopyToClipboardCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Email}">
                                                        <TextBlock Text="📋" FontSize="11"/>
                                                    </Button>
                                                </StackPanel>

                                                <!-- Password -->
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🔒" FontSize="11" Margin="0,0,6,0"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Password}"
                                                               FontSize="{StaticResource FontSizeMd}"
                                                               Foreground="{StaticResource TextPlaceholderBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <Button Style="{StaticResource BtnGhost}"
                                                            Padding="5,3" Margin="6,0,0,0"
                                                            ToolTip="نسخ كلمة المرور"
                                                            Command="{Binding DataContext.CopyToClipboardCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Password}">
                                                        <TextBlock Text="📋" FontSize="11"/>
                                                    </Button>
                                                </StackPanel>

                                            </StackPanel>

                                            <!-- Open Arrow -->
                                            <StackPanel Grid.Column="3"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <Border Width="34" Height="34"
                                                        Background="{StaticResource InfoLightBrush}"
                                                        CornerRadius="8">
                                                    <TextBlock Text="🔗" FontSize="15"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="فتح"
                                                           FontSize="{StaticResource FontSizeXs}"
                                                           Foreground="{StaticResource InfoBrush}"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty -->
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCard}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Accounts.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🖥️" FontSize="24"
                                       HorizontalAlignment="Center" Margin="0,0,0,7"/>
                            <TextBlock Text="لا توجد حسابات مرتبطة بهذه الشركة"
                                       FontSize="{StaticResource FontSizeMd}"
                                       Foreground="{StaticResource TextPlaceholderBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>