<UserControl x:Class="SA.Accounting.WPF.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="860"
             FlowDirection="RightToLeft"
             Background="{StaticResource SurfaceHoverBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,20,24,32">

            <!-- ══════════════════════════════════
                 PROFILE HEADER CARD
            ══════════════════════════════════ -->
            <Border Style="{StaticResource ContentCard}" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">

                    <!-- Avatar -->
                    <Border Style="{StaticResource ProfileAvatarLg}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A1F3A" Offset="0"/>
                                <GradientStop Color="#252B48" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="{Binding Initials}"
                                   Style="{StaticResource ProfileAvatarText}"/>
                    </Border>

                    <!-- Info -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Email}"
                                   FontSize="{StaticResource FontSizeMd}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,3,0,0"/>
                        <TextBlock Text="إدارة معلوماتك الشخصية وإعدادات الأمان"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Foreground="{StaticResource TextPlaceholderBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════
                 SIDEBAR + CONTENT
            ══════════════════════════════════ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ══════ SIDEBAR ══════ -->
                <Border Grid.Column="0" Style="{StaticResource ContentCard}">
                    <StackPanel>

                        <!-- Personal Info Nav -->
                        <Border Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding ShowPersonalInfoCommand}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border"
                                       BasedOn="{StaticResource ProfileNavItem}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPersonalInfoSelected}"
                                                     Value="True">
                                            <Setter Property="Background"
                                                    Value="{StaticResource InfoLightBrush}"/>
                                            <Setter Property="BorderBrush"
                                                    Value="{StaticResource InfoBrush}"/>
                                            <Setter Property="BorderThickness" Value="0,0,3,0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤" Style="{StaticResource ProfileNavIcon}"/>
                                <TextBlock Text="المعلومات الشخصية">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource ProfileNavText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPersonalInfoSelected}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource InfoBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Security Nav -->
                        <Border Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding ShowSecurityCommand}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border"
                                       BasedOn="{StaticResource ProfileNavItem}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSecuritySelected}"
                                                     Value="True">
                                            <Setter Property="Background"
                                                    Value="{StaticResource InfoLightBrush}"/>
                                            <Setter Property="BorderBrush"
                                                    Value="{StaticResource InfoBrush}"/>
                                            <Setter Property="BorderThickness" Value="0,0,3,0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔒" Style="{StaticResource ProfileNavIcon}"/>
                                <TextBlock Text="الأمان وكلمة المرور">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource ProfileNavText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSecuritySelected}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource InfoBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ══════ CONTENT ══════ -->
                <Grid Grid.Column="2">

                    <!-- ═══════════════════════════════
                         PERSONAL INFORMATION PANEL
                    ═══════════════════════════════ -->
                    <Border Style="{StaticResource ContentCard}"
                            Visibility="{Binding IsPersonalInfoSelected,
                                        Converter={StaticResource BoolToVis}}">
                        <StackPanel>

                            <!-- Section Title -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <TextBlock Text="👤"
                                           Style="{StaticResource ProfileSectionIcon}"/>
                                <TextBlock Text="المعلومات الشخصية"
                                           Style="{StaticResource ProfileSectionTitle}"/>
                            </StackPanel>

                            <!-- Name + SSN -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Name -->
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="الاسم"
                                                   Style="{StaticResource InputLabel}"
                                                   Margin="0"/>
                                        <TextBlock Style="{StaticResource RequiredStar}"/>
                                    </StackPanel>
                                    <telerik:RadWatermarkTextBox
                                        Text="{Binding Name, Mode=TwoWay,
                                               UpdateSourceTrigger=PropertyChanged}"
                                        WatermarkContent="أدخل الاسم الكامل"
                                        Style="{StaticResource InputDefault}"/>
                                </StackPanel>

                                <!-- SSN -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="رقم الهوية الوطنية"
                                               Style="{StaticResource InputLabel}"/>
                                    <telerik:RadWatermarkTextBox
                                        Text="{Binding SSN, Mode=TwoWay,
                                               UpdateSourceTrigger=PropertyChanged}"
                                        WatermarkContent="أدخل رقم الهوية"
                                        Style="{StaticResource InputDefault}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Phone + Email -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Phone -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="رقم الهاتف"
                                               Style="{StaticResource InputLabel}"/>
                                    <telerik:RadWatermarkTextBox
                                        Text="{Binding PhoneNumber, Mode=TwoWay,
                                               UpdateSourceTrigger=PropertyChanged}"
                                        WatermarkContent="أدخل رقم الهاتف"
                                        Style="{StaticResource InputDefault}"/>
                                </StackPanel>

                                <!-- Email (Read Only) -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="البريد الإلكتروني"
                                               Style="{StaticResource InputLabel}"/>
                                    <Border Style="{StaticResource InputReadOnlyBorder}">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="📧"
                                                       FontSize="14" Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Email}"
                                                       Style="{StaticResource InputReadOnly}"
                                                       FlowDirection="LeftToRight"/>
                                            <TextBlock Grid.Column="2" Text="🔒"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.5"/>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="لا يمكن تغيير البريد الإلكتروني"
                                               FontSize="{StaticResource FontSizeXs}"
                                               Foreground="{StaticResource TextPlaceholderBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Save Button -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        Margin="0,10,0,0">
                                <telerik:RadButton Style="{StaticResource RadBtnPrimary}"
                                                   MinWidth="140" Height="36"
                                                   Command="{Binding SaveProfileCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✓" FontSize="13" Foreground="White"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Text="حفظ التغييرات"
                                                   FontSize="{StaticResource FontSizeMd}"
                                                   FontWeight="SemiBold" Foreground="White"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </telerik:RadButton>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════════════════
                         SECURITY & PASSWORD PANEL
                    ═══════════════════════════════ -->
                    <!-- ═══════════════════════════════
                         SECURITY & PASSWORD PANEL
                    ═══════════════════════════════ -->
                    <Border Visibility="{Binding IsSecuritySelected,
                                        Converter={StaticResource BoolToVis}}">
                        <Border.Style>
                            <Style TargetType="Border"
                                   BasedOn="{StaticResource ContentCard}"/>
                        </Border.Style>
                        <StackPanel>

                            <!-- Section Title -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <TextBlock Text="🔒"
                                           Style="{StaticResource ProfileSectionIcon}"/>
                                <TextBlock Text="تغيير كلمة المرور"
                                           Style="{StaticResource ProfileSectionTitle}"/>
                            </StackPanel>

                            <!-- Password Fields Container -->
                            <StackPanel MaxWidth="450"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,0,0,0">

                                <!-- Current Password -->
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="كلمة المرور الحالية"
                                               Style="{StaticResource InputLabel}"/>
                                    <telerik:RadPasswordBox
                                        x:Name="CurrentPasswordBox"
                                        PasswordChanged="CurrentPasswordBox_PasswordChanged"
                                        Height="{StaticResource InputHeightLg}"
                                        FontSize="{StaticResource FontSizeMd}"
                                        HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <!-- New Password -->
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="كلمة المرور الجديدة"
                                               Style="{StaticResource InputLabel}"/>
                                    <telerik:RadPasswordBox
                                        x:Name="NewPasswordBox"
                                        PasswordChanged="NewPasswordBox_PasswordChanged"
                                        Height="{StaticResource InputHeightLg}"
                                        FontSize="{StaticResource FontSizeMd}"
                                        HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <!-- Confirm Password -->
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="تأكيد كلمة المرور الجديدة"
                                               Style="{StaticResource InputLabel}"/>
                                    <telerik:RadPasswordBox
                                        x:Name="ConfirmPasswordBox"
                                        PasswordChanged="ConfirmPasswordBox_PasswordChanged"
                                        Height="{StaticResource InputHeightLg}"
                                        FontSize="{StaticResource FontSizeMd}"
                                        HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <!-- Hint -->
                                <Border Background="{StaticResource WarningLightBrush}"
                                        CornerRadius="{StaticResource RadiusLg}"
                                        Padding="14,10"
                                        Margin="0,0,0,16"
                                        HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠️" FontSize="14"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="كلمة المرور يجب أن تكون 6 أحرف على الأقل"
                                                   FontSize="{StaticResource FontSizeSm}"
                                                   Foreground="#92400E"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>

                            <!-- Change Password Button -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        Margin="0,10,0,0">
                                <telerik:RadButton Style="{StaticResource RadBtnPrimary}"
                                                   MinWidth="160" Height="36"
                                                   Command="{Binding ChangePasswordCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔒" FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Text="تغيير كلمة المرور"
                                                   FontSize="{StaticResource FontSizeMd}"
                                                   FontWeight="SemiBold" Foreground="White"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </telerik:RadButton>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                </Grid>

            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>