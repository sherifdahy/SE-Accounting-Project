<Window x:Class="SA.Accounting.WPF.Portals.SystemAdministration.Dialogs.Companies.CompanyFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
        Title="إضافة شركة"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanMinimize"
        Background="White"
        Width="550"
        SizeToContent="Height">

    <Window.Resources>
        <!-- Validation Error Style -->
        <Style x:Key="ValidationTextBlock" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ====================================== -->
        <!-- Header -->
        <!-- ====================================== -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock x:Name="DialogTitle"
                       Text="إضافة شركة جديدة"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#111827"
                       Margin="0,0,0,6"/>
            <TextBlock Text="قم بإدخال معلومات الشركة"
                       FontSize="13"
                       Foreground="#6B7280"/>
        </StackPanel>

        <!-- ====================================== -->
        <!-- Form -->
        <!-- ====================================== -->
        <StackPanel Grid.Row="1" Margin="0,0,0,24">

            <!-- اسم الشركة -->
            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="اسم الشركة" Style="{StaticResource InputLabelStyle}"/>
                <telerik:RadWatermarkTextBox
                    x:Name="NameTextBox"
                    Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"
                    WatermarkContent="أدخل اسم الشركة..."
                    Style="{StaticResource ModernInputStyle}"
                    Validation.ErrorTemplate="{x:Null}"/>

                <TextBlock Style="{StaticResource ValidationTextBlock}"
                           Visibility="{Binding ElementName=NameTextBox, Path=(Validation.HasError), Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock.Text>
                        <Binding Path="(Validation.Errors)[0].ErrorContent"
                                 ElementName="NameTextBox"/>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <!-- رقم السجل الضريبي -->
            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="رقم السجل الضريبي" Style="{StaticResource InputLabelStyle}"/>
                <telerik:RadWatermarkTextBox
                    x:Name="TaxRegistrationNumberTextBox"
                    Text="{Binding TaxRegistrationNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"
                    WatermarkContent="000000000"
                    Style="{StaticResource ModernInputStyle}"
                    Validation.ErrorTemplate="{x:Null}"
                    MaxLength="15"/>

                <TextBlock Style="{StaticResource ValidationTextBlock}"
                           Visibility="{Binding ElementName=TaxRegistrationNumberTextBox, Path=(Validation.HasError), Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock.Text>
                        <Binding Path="(Validation.Errors)[0].ErrorContent"
                                 ElementName="TaxRegistrationNumberTextBox"/>
                    </TextBlock.Text>
                </TextBlock>

            </StackPanel>

            <!-- رقم الملف الضريبي -->
            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="رقم الملف الضريبي" Style="{StaticResource InputLabelStyle}"/>
                <telerik:RadWatermarkTextBox
                    x:Name="TaxFileNumberTextBox"
                    Text="{Binding TaxFileNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"
                    WatermarkContent="أدخل رقم الملف الضريبي..."
                    Style="{StaticResource ModernInputStyle}"
                    Validation.ErrorTemplate="{x:Null}"/>

                <TextBlock Style="{StaticResource ValidationTextBlock}"
                           Visibility="{Binding ElementName=TaxFileNumberTextBox, Path=(Validation.HasError), Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock.Text>
                        <Binding Path="(Validation.Errors)[0].ErrorContent"
                                 ElementName="TaxFileNumberTextBox"/>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <!-- العنوان -->
            <StackPanel>
                <TextBlock Text="العنوان" Style="{StaticResource InputLabelStyle}"/>
                <TextBox
                    x:Name="AddressTextBox"
                    Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"
                    Height="80"
                    TextWrapping="Wrap"
                    AcceptsReturn="True"
                    Style="{StaticResource ModernTextBoxStyle}"
                    Validation.ErrorTemplate="{x:Null}"/>

                <TextBlock Style="{StaticResource ValidationTextBlock}"
                           Visibility="{Binding ElementName=AddressTextBox, Path=(Validation.HasError), Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock.Text>
                        <Binding Path="(Validation.Errors)[0].ErrorContent"
                                 ElementName="AddressTextBox"/>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

        </StackPanel>

        <!-- ====================================== -->
        <!-- Buttons -->
        <!-- ====================================== -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <!-- زر الإلغاء بنفس الستايل بتاعك -->
            <Button Content="إلغاء"
                    Width="100"
                    Height="38"
                    Background="#F3F4F6"
                    Foreground="#374151"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- زر الحفظ بنفس الستايل -->
            <telerik:RadButton
                x:Name="SaveButton"
                Content="حفظ"
                Style="{StaticResource ModernButtonStyle}"
                Width="100"
                Height="38"
                FontSize="13"
                Click="SaveButton_Click"/>
        </StackPanel>

    </Grid>
</Window>
