<Application x:Class="SA.Accounting.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             xmlns:converters="clr-namespace:SA.Accounting.WPF.Converters"
             ShutdownMode="OnExplicitShutdown">

    <Application.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:NameToInitialsConverter x:Key="NameToInitialsConverter"/>
            <converters:PermissionToVisibilityConverter x:Key="PermissionToVisibilityConverter"/>
            <converters:ViewModelToSelectedConverter x:Key="ViewModelToSelectedConverter"/>


            <ResourceDictionary.MergedDictionaries>

                <!-- ═══ 1. Generic (الأساس - لازم الأول) ═══ -->
                <ResourceDictionary Source="Styles/Generic/Colors.xaml"/>
                <ResourceDictionary Source="Styles/Generic/Sizes.xaml"/>
                <ResourceDictionary Source="Styles/Generic/Typography.xaml"/>

                <!-- ═══ 2. Components ═══ -->
                <ResourceDictionary Source="Styles/Components/ButtonStyles.xaml"/>
                <ResourceDictionary Source="Styles/Components/InputStyles.xaml"/>
                <ResourceDictionary Source="Styles/Components/CardStyles.xaml"/>
                <ResourceDictionary Source="Styles/Components/BadgeStyles.xaml"/>
                <ResourceDictionary Source="Styles/Components/ComboBoxStyles.xaml"/>
                <ResourceDictionary Source="Styles/Components/GridStyles.xaml"/>
                <ResourceDictionary Source="Styles/Components/PagerStyles.xaml"/>
                <ResourceDictionary Source="Styles/Components/TabStyles.xaml"/>
                <ResourceDictionary Source="Styles/Components/CheckBoxStyles.xaml"/>
                <ResourceDictionary Source="Styles/Components/SearchBoxStyles.xaml"/>

                <!-- ═══ 3. Layout ═══ -->
                <ResourceDictionary Source="Styles/Layout/SidebarStyles.xaml"/>
                <ResourceDictionary Source="Styles/Layout/HeaderStyles.xaml"/>

                <!-- ═══ 4. Features ═══ -->
                <ResourceDictionary Source="Styles/Features/UserCompaniesStyles.xaml"/>
                <ResourceDictionary Source="Styles/Features/UpdateUserStyles.xaml"/>
                <ResourceDictionary Source="Styles/Features/TransactionStyles.xaml"/>
                <ResourceDictionary Source="Styles/Features/ProfileStyles.xaml"/>
                <!-- ═══ 5. DataTemplates ═══ -->
                <ResourceDictionary Source="Styles/DataTemplates.xaml"/>

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>