<UserControl
    x:Class="SA.Accounting.WPF.Portals.SystemAdministration.UserControls.Companies.UpdateCompanyControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns:vm="clr-namespace:SA.Accounting.WPF.ViewModels.Company"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:UpdateCompanyViewModel}"
    FlowDirection="RightToLeft"
    Background="#F9FAFB"
    d:DesignWidth="860">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadPlatformsCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,20,24,32">

            <!-- ══════ رأس الصفحة ══════ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Border Width="42" Height="42" Background="#1A1F3A"
                        CornerRadius="10" Margin="0,0,12,0">
                    <TextBlock Text="✏️" FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="تعديل بيانات الشركة"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#111827"/>
                    <TextBlock Text="قم بتعديل البيانات ثم اضغط حفظ التعديلات"
                               FontSize="12" Foreground="#6B7280"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- ══════ بيانات الشركة ══════ -->
            <Border Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="1" CornerRadius="10"
                    Padding="20" Margin="0,0,0,14">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.04"
                                      BlurRadius="6" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="3" Height="16" Background="#111827"
                                CornerRadius="2" VerticalAlignment="Center"
                                Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="بيانات الشركة"
                                       Style="{StaticResource SectionLabelStyle}"/>
                            <TextBlock Text="المعلومات الأساسية للشركة"
                                       FontSize="11" Foreground="#9CA3AF"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Row 1: Name + TaxReg -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="اسم الشركة"
                                           Style="{StaticResource InputLabelStyle}"
                                           Margin="0"/>
                                <TextBlock Text=" *" Foreground="#EF4444"
                                           FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                            <telerik:RadWatermarkTextBox
                                x:Name="NameBox"
                                Text="{Binding Name, Mode=TwoWay,
                                       UpdateSourceTrigger=PropertyChanged,
                                       ValidatesOnNotifyDataErrors=True}"
                                WatermarkContent="أدخل اسم الشركة"
                                Style="{StaticResource ModernInputStyle}"
                                Validation.ErrorTemplate="{x:Null}"/>
                            <TextBlock Style="{StaticResource ValidationTextBlock}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                              ElementName=NameBox}"
                                       Visibility="{Binding (Validation.HasError),
                                                    ElementName=NameBox,
                                                    Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="رقم السجل الضريبي"
                                           Style="{StaticResource InputLabelStyle}"
                                           Margin="0"/>
                                <TextBlock Text=" *" Foreground="#EF4444"
                                           FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                            <telerik:RadWatermarkTextBox
                                x:Name="TaxRegBox"
                                Text="{Binding TaxRegistrationNumber, Mode=TwoWay,
                                       UpdateSourceTrigger=PropertyChanged,
                                       ValidatesOnNotifyDataErrors=True}"
                                WatermarkContent="000000000"
                                MaxLength="15"
                                Style="{StaticResource ModernInputStyle}"
                                Validation.ErrorTemplate="{x:Null}"/>
                            <TextBlock Style="{StaticResource ValidationTextBlock}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                              ElementName=TaxRegBox}"
                                       Visibility="{Binding (Validation.HasError),
                                                    ElementName=TaxRegBox,
                                                    Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: TaxFile -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="رقم الملف الضريبي"
                                           Style="{StaticResource InputLabelStyle}"
                                           Margin="0"/>
                                <TextBlock Text=" *" Foreground="#EF4444"
                                           FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                            <telerik:RadWatermarkTextBox
                                x:Name="TaxFileBox"
                                Text="{Binding TaxFileNumber, Mode=TwoWay,
                                       UpdateSourceTrigger=PropertyChanged,
                                       ValidatesOnNotifyDataErrors=True}"
                                WatermarkContent="أدخل رقم الملف الضريبي"
                                Style="{StaticResource ModernInputStyle}"
                                Validation.ErrorTemplate="{x:Null}"/>
                            <TextBlock Style="{StaticResource ValidationTextBlock}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                              ElementName=TaxFileBox}"
                                       Visibility="{Binding (Validation.HasError),
                                                    ElementName=TaxFileBox,
                                                    Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 3: Address -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="العنوان"
                                       Style="{StaticResource InputLabelStyle}"
                                       Margin="0"/>
                            <TextBlock Text=" *" Foreground="#EF4444"
                                       FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBox x:Name="AddressBox"
                                 Text="{Binding Address, Mode=TwoWay,
                                        UpdateSourceTrigger=PropertyChanged,
                                        ValidatesOnNotifyDataErrors=True}"
                                 Height="68" TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Validation.ErrorTemplate="{x:Null}"/>
                        <TextBlock Style="{StaticResource ValidationTextBlock}"
                                   Text="{Binding (Validation.Errors)[0].ErrorContent,
                                          ElementName=AddressBox}"
                                   Visibility="{Binding (Validation.HasError),
                                                ElementName=AddressBox,
                                                Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ══════ المالكون ══════ -->
            <Border Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="1" CornerRadius="10"
                    Padding="20" Margin="0,0,0,14">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.04"
                                      BlurRadius="6" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Width="3" Height="16" Background="#FFB800"
                                    CornerRadius="2" VerticalAlignment="Center"
                                    Margin="0,0,8,0"/>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="المالكون"
                                               Style="{StaticResource SectionLabelStyle}"/>
                                    <Border Style="{StaticResource BadgeYellow}">
                                        <TextBlock Text="{Binding Owners.Count}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#92400E"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="أضف مالكي الشركة"
                                           FontSize="11" Foreground="#9CA3AF"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource AddButtonDark}"
                                Command="{Binding AddOwnerCommand}"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="2,0">
                                <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"
                                           Margin="0,0,5,0"/>
                                <TextBlock Text="إضافة مالك" FontSize="12"
                                           FontWeight="SemiBold" Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Owners}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource RowCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="اسم المالك"
                                                       Style="{StaticResource RowLabelStyle}"/>
                                            <telerik:RadWatermarkTextBox
                                                x:Name="OwnerNameBox"
                                                Text="{Binding Name, Mode=TwoWay,
                                                       UpdateSourceTrigger=PropertyChanged,
                                                       ValidatesOnNotifyDataErrors=True}"
                                                WatermarkContent="أدخل اسم المالك"
                                                Style="{StaticResource RowInputStyle}"
                                                Validation.ErrorTemplate="{x:Null}"/>
                                            <TextBlock Style="{StaticResource ValidationTextBlock}"
                                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                                              ElementName=OwnerNameBox}"
                                                       Visibility="{Binding (Validation.HasError),
                                                                    ElementName=OwnerNameBox,
                                                                    Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="رقم الهوية الوطنية"
                                                       Style="{StaticResource RowLabelStyle}"/>
                                            <telerik:RadWatermarkTextBox
                                                x:Name="OwnerSsnBox"
                                                Text="{Binding Ssn, Mode=TwoWay,
                                                       UpdateSourceTrigger=PropertyChanged,
                                                       ValidatesOnNotifyDataErrors=True}"
                                                WatermarkContent="أدخل رقم الهوية"
                                                Style="{StaticResource RowInputStyle}"
                                                Validation.ErrorTemplate="{x:Null}"/>
                                            <TextBlock Style="{StaticResource ValidationTextBlock}"
                                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                                              ElementName=OwnerSsnBox}"
                                                       Visibility="{Binding (Validation.HasError),
                                                                    ElementName=OwnerSsnBox,
                                                                    Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>

                                        <Button Grid.Column="4"
                                                Style="{StaticResource RemoveRowButton}"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.RemoveOwnerCommand,
                                                          RelativeSource={RelativeSource
                                                          AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility"      Value="Collapsed"/>
                                <Setter Property="CornerRadius"    Value="7"/>
                                <Setter Property="Padding"         Value="16,20"/>
                                <Setter Property="BorderBrush"     Value="#E5E7EB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background"      Value="#FAFAFA"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Owners.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="👤" FontSize="24"
                                       HorizontalAlignment="Center" Margin="0,0,0,7"/>
                            <TextBlock Text="لا يوجد مالكون حتى الآن"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#374151"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="اضغط &quot;+ إضافة مالك&quot; للبدء"
                                       FontSize="11" Foreground="#9CA3AF"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ══════ حسابات المنصات ══════ -->
            <Border Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="1" CornerRadius="10"
                    Padding="20" Margin="0,0,0,14">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.04"
                                      BlurRadius="6" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Width="3" Height="16" Background="#10B981"
                                    CornerRadius="2" VerticalAlignment="Center"
                                    Margin="0,0,8,0"/>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="حسابات المنصات"
                                               Style="{StaticResource SectionLabelStyle}"/>
                                    <Border Style="{StaticResource BadgeGreen}">
                                        <TextBlock Text="{Binding Accounts.Count}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#065F46"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="أضف حسابات المنصات المرتبطة بالشركة"
                                           FontSize="11" Foreground="#9CA3AF"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource AddButtonDark}"
                                Command="{Binding AddAccountCommand}"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="2,0">
                                <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"
                                           Margin="0,0,5,0"/>
                                <TextBlock Text="إضافة حساب" FontSize="12"
                                           FontWeight="SemiBold" Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource RowCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="البريد الإلكتروني"
                                                       Style="{StaticResource RowLabelStyle}"/>
                                            <telerik:RadWatermarkTextBox
                                                x:Name="EmailBox"
                                                Text="{Binding Email, Mode=TwoWay,
                                                       UpdateSourceTrigger=PropertyChanged,
                                                       ValidatesOnNotifyDataErrors=True}"
                                                WatermarkContent="example@email.com"
                                                Style="{StaticResource RowInputStyle}"
                                                Validation.ErrorTemplate="{x:Null}"/>
                                            <TextBlock Style="{StaticResource ValidationTextBlock}"
                                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                                              ElementName=EmailBox}"
                                                       Visibility="{Binding (Validation.HasError),
                                                                    ElementName=EmailBox,
                                                                    Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="كلمة المرور"
                                                       Style="{StaticResource RowLabelStyle}"/>
                                            <telerik:RadWatermarkTextBox
                                                x:Name="PasswordBox"
                                                Text="{Binding Password, Mode=TwoWay,
                                                       UpdateSourceTrigger=PropertyChanged,
                                                       ValidatesOnNotifyDataErrors=True}"
                                                WatermarkContent="••••••••"
                                                Style="{StaticResource RowInputStyle}"
                                                Validation.ErrorTemplate="{x:Null}"/>
                                            <TextBlock Style="{StaticResource ValidationTextBlock}"
                                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                                              ElementName=PasswordBox}"
                                                       Visibility="{Binding (Validation.HasError),
                                                                    ElementName=PasswordBox,
                                                                    Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="المنصة"
                                                       Style="{StaticResource RowLabelStyle}"/>
                                            <telerik:RadComboBox
                                                SelectedValue="{Binding PlatformId, Mode=TwoWay}"
                                                SelectedValuePath="Id"
                                                DisplayMemberPath="Name"
                                                ItemsSource="{Binding DataContext.Platforms,
                                                              RelativeSource={RelativeSource
                                                              AncestorType=UserControl}}"
                                                Style="{StaticResource ModernComboBoxStyle}"/>
                                        </StackPanel>

                                        <Button Grid.Column="6"
                                                Style="{StaticResource RemoveRowButton}"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.RemoveAccountCommand,
                                                          RelativeSource={RelativeSource
                                                          AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility"      Value="Collapsed"/>
                                <Setter Property="CornerRadius"    Value="7"/>
                                <Setter Property="Padding"         Value="16,20"/>
                                <Setter Property="BorderBrush"     Value="#E5E7EB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background"      Value="#FAFAFA"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Accounts.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🖥️" FontSize="24"
                                       HorizontalAlignment="Center" Margin="0,0,0,7"/>
                            <TextBlock Text="لا توجد حسابات حتى الآن"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#374151"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="اضغط &quot;+ إضافة حساب&quot; للبدء"
                                       FontSize="11" Foreground="#9CA3AF"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ══════ أزرار الإجراءات ══════ -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Margin="0,6,0,0">

                <Button Style="{StaticResource CancelButtonStyle}"
                        Width="100" Margin="0,0,10,0"
                        Command="{Binding CancelCommand}">
                    <TextBlock Text="إلغاء" FontSize="12"
                               FontWeight="SemiBold" Foreground="#374151"/>
                </Button>

                <telerik:RadButton
                    Style="{StaticResource ModernButtonStyle}"
                    MinWidth="130" Height="34"
                    Command="{Binding SaveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" FontSize="13" Foreground="White"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="حفظ التعديلات" FontSize="12"
                                   FontWeight="SemiBold" Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </telerik:RadButton>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>