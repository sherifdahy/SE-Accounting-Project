<UserControl 
        FlowDirection="RightToLeft" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:SA.Accounting.WPF.Portals.SystemAdministration.UserControls.Companies" 
        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" 
        x:Class="SA.Accounting.WPF.Portals.SystemAdministration.UserControls.Companies.CompaniesControl" 
    mc:Ignorable="d" d:DesignHeight="500" d:DesignWidth="800" Loaded="UserControl_Loaded" Background="#F9FAFB">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,32">

                <!-- 📊 Stats Cards Row -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card 1: إجمالي الشركات -->
                    <Border Grid.Column="0" 
                        Background="White"
                        CornerRadius="10"
                        Padding="16"
                        Margin="0,0,8,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" 
                                        Opacity="0.05" 
                                        BlurRadius="8" 
                                        ShadowDepth="2" 
                                        Direction="270"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="إجمالي الشركات" 
                                       FontSize="12" 
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Right"/>
                                <Border Background="#EFF6FF"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="8"
                                    HorizontalAlignment="Left">
                                    <TextBlock Text="🏢" 
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="TotalCompaniesText"
                                   Text="0" 
                                   FontSize="26" 
                                   FontWeight="Bold"
                                   Foreground="#111827"
                                   Margin="0,0,0,3"/>
                            <TextBlock Text="شركة نشطة" 
                                   FontSize="11" 
                                   Foreground="#10B981"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 2: إجمالي الموظفين -->
                    <Border Grid.Column="1" 
                        Background="White"
                        CornerRadius="10"
                        Padding="16"
                        Margin="0,0,8,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" 
                                        Opacity="0.05" 
                                        BlurRadius="8" 
                                        ShadowDepth="2" 
                                        Direction="270"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="إجمالي الموظفين" 
                                       FontSize="12" 
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Right"/>
                                <Border Background="#FEF3C7"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="8"
                                    HorizontalAlignment="Left">
                                    <TextBlock Text="👥" 
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="TotalEmployeesText"
                                   Text="0" 
                                   FontSize="26" 
                                   FontWeight="Bold"
                                   Foreground="#111827"
                                   Margin="0,0,0,3"/>
                            <TextBlock Text="عبر جميع الشركات" 
                                   FontSize="11" 
                                   Foreground="#6B7280"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 3: إجمالي العهد -->
                    <Border Grid.Column="2" 
                        Background="White"
                        CornerRadius="10"
                        Padding="16"
                        Margin="0,0,8,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" 
                                        Opacity="0.05" 
                                        BlurRadius="8" 
                                        ShadowDepth="2" 
                                        Direction="270"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="إجمالي العهد" 
                                       FontSize="12" 
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Right"/>
                                <Border Background="#DBEAFE"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="8"
                                    HorizontalAlignment="Left">
                                    <TextBlock Text="💰" 
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="TotalTransactionsText"
                                   Text="0" 
                                   FontSize="26" 
                                   FontWeight="Bold"
                                   Foreground="#111827"
                                   Margin="0,0,0,3"/>
                            <TextBlock Text="عهدة نشطة" 
                                   FontSize="11" 
                                   Foreground="#6B7280"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 4: إجمالي المنظمات -->
                    <Border Grid.Column="3" 
                        Background="White"
                        CornerRadius="10"
                        Padding="16">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" 
                                        Opacity="0.05" 
                                        BlurRadius="8" 
                                        ShadowDepth="2" 
                                        Direction="270"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="إجمالي المنظمات" 
                                       FontSize="12" 
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Right"/>
                                <Border Background="#F3E8FF"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="8"
                                    HorizontalAlignment="Left">
                                    <TextBlock Text="🏛️" 
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="TotalOrganizationsText"
                                   Text="0" 
                                   FontSize="26" 
                                   FontWeight="Bold"
                                   Foreground="#111827"
                                   Margin="0,0,0,3"/>
                            <TextBlock Text="منظمة مسجلة" 
                                   FontSize="11" 
                                   Foreground="#6B7280"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 📋 All Companies Section -->
                <Border Background="White"
                    CornerRadius="10"
                    Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" 
                                    Opacity="0.05" 
                                    BlurRadius="8" 
                                    ShadowDepth="2" 
                                    Direction="270"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header: Title + Button -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="جميع الشركات" 
                                       FontSize="16" 
                                       FontWeight="Bold"
                                       Foreground="#111827"/>
                                <TextBlock Text="إدارة ومتابعة معلومات الشركات" 
                                       FontSize="12" 
                                       Foreground="#6B7280"
                                       Margin="0,3,0,0"/>
                            </StackPanel>

                            <telerik:RadButton
                            Grid.Column="1"
                            x:Name="AddCompanyButton"
                            Content="+ إضافة شركة"
                            Style="{StaticResource ModernButtonStyle}"
                            Width="130"
                            Height="36"
                            FontSize="13"
                            Click="AddCompanyButton_Click"/>
                        </Grid>
                        <!-- Search Box + Filter -->
                        <Grid Grid.Row="1" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search Box -->
                            <telerik:RadWatermarkTextBox
                                Grid.Column="0"
                                x:Name="SearchBox"
                                KeyUp="SearchBox_KeyUp"
                                WatermarkContent="ابحث عن شركة..."
                                Style="{StaticResource ModernInputStyle}"
                                Height="38"
                                FontSize="13"
                                Width="300"
                                Margin="0,0,10,0"/>

                            <!-- Filter Dropdown -->
                            <telerik:RadComboBox
                                Grid.Column="1"
                                x:Name="FilterComboBox"
                                Style="{StaticResource ModernComboBoxStyle}"
                                Width="180"
                                Height="38"
                                SelectedIndex="0"
                                SelectionChanged="FilterComboBox_SelectionChanged">
                                <telerik:RadComboBoxItem Content="النشطة فقط" Tag="false"/>
                                <telerik:RadComboBoxItem Content="جميع الشركات" Tag="true"/>
                            </telerik:RadComboBox>
                        </Grid>


                        <!-- Table -->
                        <telerik:RadGridView
                        Grid.Row="2"
                        x:Name="CompaniesDataGrid"
                        RowActivated="CompaniesDataGrid_RowActivated"
                        Style="{StaticResource ModernGridViewStyle}"
                        IsReadOnly="True"
                        CanUserSortColumns="True"
                        CanUserResizeColumns="True"
                        CanUserReorderColumns="False"
                        RowHeight="52"
                        BorderThickness="0">

                            <telerik:RadGridView.Columns>

                                <!-- اسم الشركة -->
                                <telerik:GridViewDataColumn 
                                DataMemberBinding="{Binding Name}"
                                Header="اسم الشركة"
                                Width="2*"
                                HeaderCellStyle="{StaticResource ModernGridViewHeaderStyle}">
                                    <telerik:GridViewDataColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" 
                                                           FontWeight="Medium"
                                                           FontSize="13"
                                                           Foreground="#111827"/>
                                                    <TextBlock FontSize="11"
                                                           Foreground="#6B7280"
                                                           Margin="0,1,0,0">
                                                    <Run Text="سجل ضريبي: "/>
                                                    <Run Text="{Binding TaxRegistrationNumber, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </telerik:GridViewDataColumn.CellTemplate>
                                </telerik:GridViewDataColumn>

                                <!-- رقم الملف الضريبي -->
                                <telerik:GridViewDataColumn 
                                DataMemberBinding="{Binding TaxFileNumber}"
                                Header="الملف الضريبي"
                                Width="*"
                                HeaderCellStyle="{StaticResource ModernGridViewHeaderStyle}">
                                    <telerik:GridViewDataColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TaxFileNumber}" 
                                                   Foreground="#111827"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </telerik:GridViewDataColumn.CellTemplate>
                                </telerik:GridViewDataColumn>

                                <!-- العنوان -->
                                <telerik:GridViewDataColumn 
                                DataMemberBinding="{Binding Address}"
                                Header="العنوان"
                                Width="2*"
                                HeaderCellStyle="{StaticResource ModernGridViewHeaderStyle}">
                                    <telerik:GridViewDataColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Address}" 
                                                   Foreground="#111827"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   ToolTip="{Binding Address}"/>
                                        </DataTemplate>
                                    </telerik:GridViewDataColumn.CellTemplate>
                                </telerik:GridViewDataColumn>

                                <!-- الحالة -->
                                <telerik:GridViewDataColumn 
                                DataMemberBinding="{Binding IsDeleted}"
                                Header="الحالة"
                                Width="100"
                                HeaderCellStyle="{StaticResource ModernGridViewHeaderStyle}">
                                    <telerik:GridViewDataColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border HorizontalAlignment="Center"
                                                CornerRadius="10"
                                                Padding="8,3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="نشط"/>
                                                            <Setter Property="Foreground" Value="#059669"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                                    <Setter Property="Text" Value="محذوف"/>
                                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </telerik:GridViewDataColumn.CellTemplate>
                                </telerik:GridViewDataColumn>

                                <!-- الإجراءات -->
                                <telerik:GridViewDataColumn 
                                Header="الإجراءات" 
                                Width="150"
                                IsSortable="False"
                                IsFilterable="False"
                                HeaderCellStyle="{StaticResource ModernGridViewHeaderStyle}">
                                    <telerik:GridViewDataColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" 
                                                    HorizontalAlignment="Center" 
                                                    VerticalAlignment="Center">

                                                <!-- زر التعديل -->
                                                <Button Content="تعديل"
                                                    Style="{StaticResource EditButton}"
                                                    Height="30"
                                                    Width="60"
                                                    FontSize="12"
                                                    Click="EditBtn_Click"
                                                    Tag="{Binding}"
                                                    Margin="0,0,6,0"/>

                                                <!-- زر الحذف -->
                                                <Button Content="حذف"
                                                    Style="{StaticResource DeleteButton}"
                                                    Height="30"
                                                    Width="60"
                                                    FontSize="12"
                                                    Click="DeleteBtn_Click"
                                                    Tag="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </telerik:GridViewDataColumn.CellTemplate>
                                </telerik:GridViewDataColumn>

                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>

                        <!-- Pagination -->
                        <Grid Grid.Row="3" Margin="0,16,0,0">
                            <TextBlock x:Name="PaginationInfo"
                                   Text="عرض 1-10 من 100 شركة"
                                   FontSize="12"
                                   Foreground="#6B7280"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"/>

                            <telerik:RadDataPager
                            x:Name="CompaniesDataPager"
                            PageSize="10"
                            Source="{Binding ItemsSource, ElementName=CompaniesDataGrid}"
                            IsTotalItemCountFixed="True"
                            Style="{StaticResource ModernDataPagerStyle}"
                            FontSize="12"
                            HorizontalAlignment="Center"/>
                        </Grid>

                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>