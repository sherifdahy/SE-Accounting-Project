<UserControl
    x:Class="SA.Accounting.WPF.Portals.SystemAdministration.UserControls.Companies.DisplayCompanyControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns:vm="clr-namespace:SA.Accounting.WPF.ViewModels.Company"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:DisplayCompanyViewModel}"
    FlowDirection="RightToLeft"
    Background="#F9FAFB"
    d:DesignWidth="860">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,20,24,32">

            <!-- ══════════════════════════════════════ -->
            <!-- ══════ رأس الصفحة + زر الرجوع ══════ -->
            <!-- ══════════════════════════════════════ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="46" Height="46" Background="#1A1F3A"
                            CornerRadius="12" Margin="0,0,14,0">
                        <TextBlock Text="🏢" FontSize="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="#111827"/>
                            <!-- Status Badge -->
                            <Border CornerRadius="8" Padding="10,3"
                                    Margin="12,0,0,0" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#D1FAE5"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                <Setter Property="Background" Value="#FEE2E2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="نشطة"/>
                                            <Setter Property="Foreground" Value="#059669"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                    <Setter Property="Text"       Value="محذوفة"/>
                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="تفاصيل الشركة والحسابات المرتبطة بها"
                                   FontSize="12" Foreground="#6B7280"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Back Button -->
                <Button Grid.Column="1"
                        Style="{StaticResource BackButtonStyle}"
                        Click="BackButton_Click"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="→" FontSize="16" Foreground="#6B7280"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="رجوع للقائمة" FontSize="12"
                                   Foreground="#6B7280" FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ══════════════════════════════════════ -->
            <!-- ══════ بطاقات المعلومات السريعة ══════ -->
            <!-- ══════════════════════════════════════ -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card: Tax Reg -->
                <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB"
                        BorderThickness="1" CornerRadius="10" Padding="16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.03"
                                          BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="30" Height="30" Background="#EFF6FF"
                                    CornerRadius="7">
                                <TextBlock Text="📋" FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="السجل الضريبي" FontSize="11"
                                       Foreground="#9CA3AF" VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TaxRegistrationNumber}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="#111827"/>
                    </StackPanel>
                </Border>

                <!-- Card: Tax File -->
                <Border Grid.Column="2" Background="White" BorderBrush="#E5E7EB"
                        BorderThickness="1" CornerRadius="10" Padding="16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.03"
                                          BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="30" Height="30" Background="#FEF3C7"
                                    CornerRadius="7">
                                <TextBlock Text="📄" FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="الملف الضريبي" FontSize="11"
                                       Foreground="#9CA3AF" VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TaxFileNumber}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="#111827"/>
                    </StackPanel>
                </Border>

                <!-- Card: Accounts Count -->
                <Border Grid.Column="4" Background="White" BorderBrush="#E5E7EB"
                        BorderThickness="1" CornerRadius="10" Padding="16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.03"
                                          BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="30" Height="30" Background="#EDE9FE"
                                    CornerRadius="7">
                                <TextBlock Text="🌐" FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="حسابات المنصات" FontSize="11"
                                       Foreground="#9CA3AF" VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Accounts.Count}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="#111827"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════ -->
            <!-- ══════ العنوان ══════════════════════ -->
            <!-- ══════════════════════════════════════ -->
            <Border Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="1" CornerRadius="10"
                    Padding="18" Margin="0,0,0,14">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.03"
                                      BlurRadius="6" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="📍" FontSize="13" Margin="0,0,5,0"/>
                        <TextBlock Text="العنوان" Style="{StaticResource InfoLabel}"
                                   Margin="0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Address}"
                               Style="{StaticResource InfoValue}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════ -->
            <!-- ══════ المالكون ══════════════════════ -->
            <!-- ══════════════════════════════════════ -->
            <Border Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="1" CornerRadius="10"
                    Padding="20" Margin="0,0,0,14">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.03"
                                      BlurRadius="6" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="3" Height="16" Background="#F59E0B"
                                CornerRadius="2" VerticalAlignment="Center"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="المالكون" FontSize="14"
                                   FontWeight="SemiBold" Foreground="#111827"/>
                        <Border Background="#FEF3C7" CornerRadius="8"
                                Padding="8,2" Margin="8,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding Owners.Count}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="#92400E"/>
                        </Border>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Owners}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource OwnerCardStyle}"
                                        Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Avatar -->
                                        <Border Width="38" Height="38"
                                                Background="#FDE68A"
                                                CornerRadius="19"
                                                Margin="0,0,12,0">
                                            <TextBlock Text="👤" FontSize="16"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#111827"/>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,2,0,0">
                                                <TextBlock Text="هوية:" FontSize="11"
                                                           Foreground="#9CA3AF"
                                                           Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding SSN}"
                                                           FontSize="11"
                                                           Foreground="#6B7280"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty -->
                    <Border Padding="16,20" CornerRadius="7" Background="#FAFAFA"
                            BorderBrush="#E5E7EB" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Owners.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="لا يوجد مالكون مسجلون"
                                   FontSize="12" Foreground="#9CA3AF"
                                   HorizontalAlignment="Center"/>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════ -->
            <!-- ══════ حسابات المنصات — Clickable Cards ══════ -->
            <!-- ══════════════════════════════════════════════ -->
            <Border Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="1" CornerRadius="10"
                    Padding="20" Margin="0,0,0,14">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.03"
                                      BlurRadius="6" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="3" Height="16" Background="#6366F1"
                                CornerRadius="2" VerticalAlignment="Center"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="حسابات المنصات" FontSize="14"
                                   FontWeight="SemiBold" Foreground="#111827"/>
                        <Border Background="#EEF2FF" CornerRadius="8"
                                Padding="8,2" Margin="8,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding Accounts.Count}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="#4338CA"/>
                        </Border>
                        <TextBlock Text="   •   اضغط على أي حساب لفتح المنصة"
                                   FontSize="11" Foreground="#9CA3AF"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- DataContext = AccountResponse -->
                                <Border Style="{StaticResource AccountCardClickable}"
                                        Margin="0,0,8,8"
                                        MouseLeftButtonUp="AccountCard_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Platform Icon -->
                                        <Border Grid.Column="0" Width="46" Height="46"
                                                CornerRadius="12" Background="#EEF2FF">
                                            <TextBlock Text="🌐" FontSize="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Account Details -->
                                        <StackPanel Grid.Column="2"
                                                    VerticalAlignment="Center">

                                            <!-- Platform Name -->
                                            <TextBlock Text="{Binding Platform.Name,
                                                              FallbackValue='منصة'}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#111827"
                                                       Margin="0,0,0,4"/>

                                            <!-- Email -->
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,3">
                                                <TextBlock Text="📧" FontSize="11"
                                                           Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Email}"
                                                           FontSize="12"
                                                           Foreground="#4B5563"
                                                           VerticalAlignment="Center"/>
                                                <Button Style="{StaticResource CopyBtnStyle}"
                                                        Margin="6,0,0,0"
                                                        Click="CopyEmail_Click"
                                                        Tag="{Binding Email}">
                                                    <TextBlock Text="📋" FontSize="11"/>
                                                </Button>
                                            </StackPanel>

                                            <!-- Password -->
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🔒" FontSize="11"
                                                           Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Password}"
                                                           FontSize="12"
                                                           Foreground="#9CA3AF"
                                                           VerticalAlignment="Center"/>
                                                <Button Style="{StaticResource CopyBtnStyle}"
                                                        Margin="6,0,0,0"
                                                        Click="CopyPassword_Click"
                                                        Tag="{Binding Password}">
                                                    <TextBlock Text="📋" FontSize="11"/>
                                                </Button>
                                            </StackPanel>

                                        </StackPanel>

                                        <!-- Open Arrow -->
                                        <StackPanel Grid.Column="3"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center">
                                            <Border Width="34" Height="34"
                                                    Background="#EEF2FF"
                                                    CornerRadius="8">
                                                <TextBlock Text="🔗" FontSize="15"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="فتح" FontSize="10"
                                                       Foreground="#6366F1"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty -->
                    <Border Padding="16,24" CornerRadius="7" Background="#FAFAFA"
                            BorderBrush="#E5E7EB" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Accounts.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🖥️" FontSize="24"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,7"/>
                            <TextBlock Text="لا توجد حسابات مرتبطة بهذه الشركة"
                                       FontSize="12" Foreground="#9CA3AF"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>