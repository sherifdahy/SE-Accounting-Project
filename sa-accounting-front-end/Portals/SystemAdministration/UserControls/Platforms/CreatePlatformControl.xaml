<UserControl
    x:Class="SA.Accounting.WPF.Portals.SystemAdministration.UserControls.Platforms.CreatePlatformControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns:vm="clr-namespace:SA.Accounting.WPF.ViewModels.Platform"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:CreatePlatformViewModel}"
    FlowDirection="RightToLeft"
    Background="#F9FAFB"
    d:DesignWidth="860">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,20,24,32">

            <!-- ══════ رأس الصفحة ══════ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Border Width="42" Height="42" Background="#1A1F3A"
                        CornerRadius="10" Margin="0,0,12,0">
                    <TextBlock Text="🌐" FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="إنشاء منصة جديدة"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#111827"/>
                    <TextBlock Text="قم بتعبئة البيانات التالية لتسجيل منصة جديدة في النظام"
                               FontSize="12" Foreground="#6B7280"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- ══════ بيانات المنصة ══════ -->
            <Border Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="1" CornerRadius="10"
                    Padding="20" Margin="0,0,0,14">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.04"
                                      BlurRadius="6" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel>

                    <!-- Section Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="3" Height="16" Background="#111827"
                                CornerRadius="2" VerticalAlignment="Center"
                                Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="بيانات المنصة"
                                       Style="{StaticResource SectionLabelStyle}"/>
                            <TextBlock Text="المعلومات الأساسية للمنصة"
                                       FontSize="11" Foreground="#9CA3AF"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Row 1: Name + Url -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- اسم المنصة -->
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="اسم المنصة"
                                           Style="{StaticResource InputLabelStyle}"
                                           Margin="0"/>
                                <TextBlock Text=" *" Foreground="#EF4444"
                                           FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                            <telerik:RadWatermarkTextBox
                                x:Name="NameBox"
                                Text="{Binding Name, Mode=TwoWay,
                                       UpdateSourceTrigger=PropertyChanged,
                                       ValidatesOnNotifyDataErrors=True}"
                                WatermarkContent="أدخل اسم المنصة"
                                Style="{StaticResource ModernInputStyle}"
                                Validation.ErrorTemplate="{x:Null}"/>
                            <TextBlock Style="{StaticResource ValidationTextBlock}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                              ElementName=NameBox}"
                                       Visibility="{Binding (Validation.HasError),
                                                    ElementName=NameBox,
                                                    Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <!-- رابط المنصة -->
                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="رابط المنصة"
                                           Style="{StaticResource InputLabelStyle}"
                                           Margin="0"/>
                                <TextBlock Text=" *" Foreground="#EF4444"
                                           FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                            <telerik:RadWatermarkTextBox
                                x:Name="UrlBox"
                                Text="{Binding Url, Mode=TwoWay,
                                       UpdateSourceTrigger=PropertyChanged,
                                       ValidatesOnNotifyDataErrors=True}"
                                WatermarkContent="https://example.com"
                                Style="{StaticResource ModernInputStyle}"
                                FlowDirection="LeftToRight"
                                Validation.ErrorTemplate="{x:Null}"/>
                            <TextBlock Style="{StaticResource ValidationTextBlock}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                              ElementName=UrlBox}"
                                       Visibility="{Binding (Validation.HasError),
                                                    ElementName=UrlBox,
                                                    Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: ImageUrl + Preview -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- رابط الصورة -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="رابط الصورة (اختياري)"
                                       Style="{StaticResource InputLabelStyle}"/>
                            <telerik:RadWatermarkTextBox
                                x:Name="ImageUrlBox"
                                Text="{Binding ImageUrl, Mode=TwoWay,
                                       UpdateSourceTrigger=PropertyChanged,
                                       ValidatesOnNotifyDataErrors=True}"
                                WatermarkContent="https://example.com/logo.png"
                                Style="{StaticResource ModernInputStyle}"
                                FlowDirection="LeftToRight"
                                Validation.ErrorTemplate="{x:Null}"/>
                            <TextBlock Style="{StaticResource ValidationTextBlock}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent,
                                              ElementName=ImageUrlBox}"
                                       Visibility="{Binding (Validation.HasError),
                                                    ElementName=ImageUrlBox,
                                                    Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <!-- معاينة الصورة -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                            <Border Background="#F9FAFB"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Height="34"
                                    Padding="8,0">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">

                                    <Image Source="{Binding ImageUrl}"
                                           MaxHeight="24" MaxWidth="24"
                                           Stretch="Uniform" Margin="0,0,8,0"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ImageUrl}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>

                                    <TextBlock Text="🖼️" FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ImageUrl}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock FontSize="11" Foreground="#9CA3AF"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="معاينة الصورة"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ImageUrl}" Value="">
                                                        <Setter Property="Text" Value="لم يتم إدخال رابط"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Null}">
                                                        <Setter Property="Text" Value="لم يتم إدخال رابط"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- ══════ المحددات (Selectors) مع Priority & Reorder ══════ -->
            <!-- ══════════════════════════════════════════════════════ -->
            <Border Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="1" CornerRadius="10"
                    Padding="20" Margin="0,0,0,14">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.04"
                                      BlurRadius="6" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel>

                    <!-- Section Header -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Width="3" Height="16" Background="#6366F1"
                                    CornerRadius="2" VerticalAlignment="Center"
                                    Margin="0,0,8,0"/>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="المحددات (Selectors)"
                                               Style="{StaticResource SectionLabelStyle}"/>
                                    <Border Background="#EEF2FF" CornerRadius="10"
                                            Padding="7,1" Margin="6,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Selectors.Count}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#4338CA"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="أضف محددات العناصر المرتبطة بالمنصة — الترتيب يحدد الأولوية"
                                           FontSize="11" Foreground="#9CA3AF"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource AddButtonDark}"
                                Command="{Binding AddSelectorCommand}"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="2,0">
                                <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"
                                           Margin="0,0,5,0"/>
                                <TextBlock Text="إضافة محدد" FontSize="12"
                                           FontWeight="SemiBold" Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- ── Selectors List ── -->
                    <ItemsControl ItemsSource="{Binding Selectors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource RowCardStyle}"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <!-- أزرار الترتيب + رقم الأولوية -->
                                            <ColumnDefinition Width="Auto"/>
                                            <!-- مسافة -->
                                            <ColumnDefinition Width="12"/>
                                            <!-- المحتوى الأساسي -->
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- ═══ عمود الترتيب (يسار الكارد / يمين بالـ RTL) ═══ -->
                                        <StackPanel Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    Width="44">

                                            <!-- زر لفوق ▲ -->
                                            <Button Command="{Binding DataContext.MoveSelectorUpCommand,
                                                              RelativeSource={RelativeSource
                                                              AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="نقل لأعلى"
                                                    Width="32" Height="22"
                                                    Cursor="Hand"
                                                    Margin="0,0,0,2">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="4">
                                                                        <TextBlock Text="▲" FontSize="10"
                                                                                   Foreground="#6B7280"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#F3F4F6"/>
                                                                            <Setter Property="BorderBrush" Value="#6366F1"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsEnabled" Value="False">
                                                                            <Setter Property="Opacity" Value="0.3"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- رقم الأولوية (Badge) -->
                                            <Border Background="#EEF2FF"
                                                    CornerRadius="6"
                                                    Padding="6,3"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,2">
                                                <TextBlock Text="{Binding DisplayOrder}"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           Foreground="#4338CA"
                                                           HorizontalAlignment="Center"/>
                                            </Border>

                                            <!-- زر لتحت ▼ -->
                                            <Button Command="{Binding DataContext.MoveSelectorDownCommand,
                                                              RelativeSource={RelativeSource
                                                              AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="نقل لأسفل"
                                                    Width="32" Height="22"
                                                    Cursor="Hand"
                                                    Margin="0,2,0,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="4">
                                                                        <TextBlock Text="▼" FontSize="10"
                                                                                   Foreground="#6B7280"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#F3F4F6"/>
                                                                            <Setter Property="BorderBrush" Value="#6366F1"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsEnabled" Value="False">
                                                                            <Setter Property="Opacity" Value="0.3"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>

                                        <!-- ═══ المحتوى الأساسي للمحدد ═══ -->
                                        <Grid Grid.Column="2">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Row 1: Value + Remove -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="القيمة (Value)"
                                                                   Style="{StaticResource RowLabelStyle}"
                                                                   Margin="0"/>
                                                        <TextBlock Text=" *" Foreground="#EF4444"
                                                                   FontSize="11" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <telerik:RadWatermarkTextBox
                                                        x:Name="ValueBox"
                                                        Text="{Binding Value, Mode=TwoWay,
                                                               UpdateSourceTrigger=PropertyChanged,
                                                               ValidatesOnNotifyDataErrors=True}"
                                                        WatermarkContent="مثال: login-btn"
                                                        Style="{StaticResource RowInputStyle}"
                                                        FlowDirection="LeftToRight"
                                                        Validation.ErrorTemplate="{x:Null}"/>
                                                    <TextBlock Style="{StaticResource ValidationTextBlock}"
                                                               Text="{Binding (Validation.Errors)[0].ErrorContent,
                                                                      ElementName=ValueBox}"
                                                               Visibility="{Binding (Validation.HasError),
                                                                            ElementName=ValueBox,
                                                                            Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>

                                                <Button Grid.Column="2"
                                                        Style="{StaticResource RemoveRowButton}"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.RemoveSelectorCommand,
                                                                  RelativeSource={RelativeSource
                                                                  AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>

                                            <!-- Row 2: ContentType + Type -->
                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Content Type -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="نوع المحتوى"
                                                               Style="{StaticResource RowLabelStyle}"/>
                                                    <telerik:RadComboBox
                                                        x:Name="ContentTypeBox"
                                                        SelectedItem="{Binding ContentType,
                                                                       Mode=TwoWay,
                                                                       ValidatesOnNotifyDataErrors=True}"
                                                        ItemsSource="{Binding DataContext.ContentTypes,
                                                                      RelativeSource={RelativeSource
                                                                      AncestorType=UserControl}}"
                                                        Style="{StaticResource ModernComboBoxStyle}"
                                                        Validation.ErrorTemplate="{x:Null}">
                                                        <telerik:RadComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="{Binding}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding}" Value="Data">
                                                                                    <Setter Property="Text" Value="بيانات (Data)"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding}" Value="Action">
                                                                                    <Setter Property="Text" Value="إجراء (Action)"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </telerik:RadComboBox.ItemTemplate>
                                                    </telerik:RadComboBox>
                                                    <TextBlock Style="{StaticResource ValidationTextBlock}"
                                                               Text="{Binding (Validation.Errors)[0].ErrorContent,
                                                                      ElementName=ContentTypeBox}"
                                                               Visibility="{Binding (Validation.HasError),
                                                                            ElementName=ContentTypeBox,
                                                                            Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>

                                                <!-- Selector Type -->
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="نوع المحدد"
                                                               Style="{StaticResource RowLabelStyle}"/>
                                                    <telerik:RadComboBox
                                                        x:Name="TypeBox"
                                                        SelectedItem="{Binding Type,
                                                                       Mode=TwoWay,
                                                                       ValidatesOnNotifyDataErrors=True}"
                                                        ItemsSource="{Binding DataContext.SelectorTypes,
                                                                      RelativeSource={RelativeSource
                                                                      AncestorType=UserControl}}"
                                                        Style="{StaticResource ModernComboBoxStyle}"
                                                        Validation.ErrorTemplate="{x:Null}">
                                                        <telerik:RadComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="{Binding}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding}" Value="Id">
                                                                                    <Setter Property="Text" Value="Id"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding}" Value="Name">
                                                                                    <Setter Property="Text" Value="Name"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding}" Value="Class">
                                                                                    <Setter Property="Text" Value="Class"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </telerik:RadComboBox.ItemTemplate>
                                                    </telerik:RadComboBox>
                                                    <TextBlock Style="{StaticResource ValidationTextBlock}"
                                                               Text="{Binding (Validation.Errors)[0].ErrorContent,
                                                                      ElementName=TypeBox}"
                                                               Visibility="{Binding (Validation.HasError),
                                                                            ElementName=TypeBox,
                                                                            Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty State -->
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility"      Value="Collapsed"/>
                                <Setter Property="CornerRadius"    Value="7"/>
                                <Setter Property="Padding"         Value="16,20"/>
                                <Setter Property="BorderBrush"     Value="#E5E7EB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background"      Value="#FAFAFA"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Selectors.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🎯" FontSize="24"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,7"/>
                            <TextBlock Text="لا توجد محددات حتى الآن"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#374151"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="اضغط &quot;+ إضافة محدد&quot; للبدء"
                                       FontSize="11" Foreground="#9CA3AF"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ══════ أزرار الإجراءات ══════ -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Margin="0,6,0,0">

                <Button Style="{StaticResource CancelButtonStyle}"
                        Width="100" Margin="0,0,10,0"
                        Command="{Binding CancelCommand}">
                    <TextBlock Text="إلغاء" FontSize="12"
                               FontWeight="SemiBold" Foreground="#374151"/>
                </Button>

                <telerik:RadButton
                    Style="{StaticResource ModernButtonStyle}"
                    MinWidth="130" Height="34"
                    Command="{Binding SaveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" FontSize="13" Foreground="White"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="حفظ المنصة" FontSize="12"
                                   FontWeight="SemiBold" Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </telerik:RadButton>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>